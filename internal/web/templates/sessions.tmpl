{{define "content"}}
<h1 id="page-sessions">{{if .Project}}{{.Project}} <span class="muted" style="font-weight:500;font-size:0.95rem">· sessions</span>{{else}}Sessions{{end}}</h1>
<p class="sub">Work units (Discord threads / Grok sessions) with {{if .Project}}turn activity in this project{{else}}project and turn activity{{end}} ({{len .Threads}}).</p>
{{if .Flash}}<div class="flash">{{.Flash}}</div>{{end}}
{{if .Error}}<div class="flash err">{{.Error}}</div>{{end}}

{{if .Threads}}
<div class="m-rows">
  {{range .Threads}}
  <a class="m-row" href="/sessions/{{.ThreadID}}{{if or $.Project .Project}}?project={{urlquery (or $.Project .Project)}}{{end}}">
    <span class="m-row-main">
      {{if .LastPrompt}}
      <span class="m-row-t">{{.LastPrompt}}</span>
      {{else}}
      <span class="m-row-t mono">{{.ThreadID}}</span>
      {{end}}
      <span class="m-row-s">{{if .LastPrompt}}<span class="mono">{{.ThreadID}}</span> · {{end}}{{if and (not $.Project) .Project}}{{.Project}} · {{end}}{{if .Label}}{{.Label}} · {{end}}{{if .PRNumber}}PR #{{.PRNumber}}{{if .PRState}} {{.PRState}}{{end}} · {{end}}{{.TurnCount}} turn{{if ne .TurnCount 1}}s{{end}}{{if .LastUser}} · {{.LastUser}}{{end}}{{if .UpdatedAt}} · {{.UpdatedAt}}{{end}}</span>
    </span>
  </a>
  {{end}}
</div>
<div class="table-scroll m-hide" id="sessions-table">
<table>
  <thead>
    <tr>
      <th>Thread</th>
      {{if not .Project}}<th>Project</th>{{end}}
      <th>State</th>
      <th>PR</th>
      <th>Turns</th>
      <th>Last user</th>
      <th>Updated</th>
      <th>Last prompt</th>
    </tr>
  </thead>
  <tbody>
    {{range .Threads}}
    <tr>
      <td class="mono"><a class="tid" href="/sessions/{{.ThreadID}}{{if or $.Project .Project}}?project={{urlquery (or $.Project .Project)}}{{end}}">{{.ThreadID}}</a></td>
      {{if not $.Project}}<td>{{if .Project}}<a href="/projects/{{.Project}}">{{.Project}}</a>{{else}}<span class="muted">—</span>{{end}}</td>{{end}}
      <td>
        {{if and (eq .Mode "case") (eq .Phase "closed")}}
        <span class="badge status-cancelled">closed</span>
        {{if .Resolution}}{{if or (eq .Resolution "answered") (eq .Resolution "fixed")}}<span class="badge status-done">{{.Resolution}}</span>{{else}}<span class="badge status-cancelled">{{.Resolution}}</span>{{end}}{{end}}
        {{else if eq .Label "done"}}
        <span class="badge status-done">done</span>
        {{else if eq .Label "abandoned"}}
        <span class="badge status-cancelled">abandoned</span>
        {{else if eq .Label "needs_review"}}
        <span class="badge status-warn">needs review</span>
        {{else if eq .Label "in_progress"}}
        <span class="badge live">in progress</span>
        {{else if eq .Label "blocked"}}
        <span class="badge status-warn">blocked</span>
        {{else if .Label}}
        <span class="badge">{{.Label}}</span>
        {{else if .Phase}}
        <span class="badge">{{.Phase}}</span>
        {{else}}
        <span class="muted">—</span>
        {{end}}
        {{if and (eq .Mode "case") (ne .Phase "closed") .Phase}}<span class="badge">{{.Phase}}</span>{{end}}
      </td>
      <td>
        {{if .PRNumber}}
          {{if and .PROwner .PRRepo}}
          <a class="badge{{if eq .PRState "MERGED"}} status-merged{{else if eq .PRState "CLOSED"}} status-cancelled{{else if eq .PRState "OPEN"}} live{{end}}"
             href="/prs/{{.PROwner}}/{{.PRRepo}}/{{.PRNumber}}{{if or $.Project .Project}}?project={{urlquery (or $.Project .Project)}}{{end}}">#{{.PRNumber}}{{if .PRState}} · {{.PRState}}{{end}}</a>
          {{else if .PRURL}}
          <a class="badge{{if eq .PRState "MERGED"}} status-merged{{else if eq .PRState "CLOSED"}} status-cancelled{{else if eq .PRState "OPEN"}} live{{end}}"
             href="{{.PRURL}}" target="_blank" rel="noopener">#{{.PRNumber}}{{if .PRState}} · {{.PRState}}{{end}} ↗</a>
          {{else}}
          <span class="badge">#{{.PRNumber}}{{if .PRState}} · {{.PRState}}{{end}}</span>
          {{end}}
        {{else}}
        <span class="muted">—</span>
        {{end}}
      </td>
      <td class="mono">{{.TurnCount}}</td>
      <td>{{if .LastUser}}{{.LastUser}}{{else}}<span class="muted">—</span>{{end}}</td>
      <td class="mono muted">{{if .UpdatedAt}}{{.UpdatedAt}}{{else}}—{{end}}</td>
      <td>{{if .LastPrompt}}<span class="clamp muted">{{.LastPrompt}}</span>{{else}}<span class="muted">{{if eq .TurnCount 0}}no turns recorded yet{{else}}—{{end}}</span>{{end}}</td>
    </tr>
    {{end}}
  </tbody>
</table>
</div>
{{else}}
<div class="empty" id="sessions-empty">No sessions {{if .Project}}in this project {{end}}yet. Work units appear after Discord or web starts a Grok task.</div>
{{end}}
{{end}}
