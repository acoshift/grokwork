{{define "content"}}
<p class="sub" style="margin-bottom:0.5rem">
  {{if .PRNumber}}
  <a href="/prs/{{.ActiveOwner}}/{{.ActiveRepo}}/{{.PRNumber}}{{if .Project}}?project={{urlquery .Project}}{{end}}">← PR</a>
  {{else if .ThreadID}}
  <a href="/sessions/{{.ThreadID}}{{if .Project}}?project={{urlquery .Project}}{{end}}">← Session</a>
  {{end}}
</p>
<h1 id="page-diff">{{.Title}}</h1>
<p class="sub">
  {{if and .ThreadID (not .PRNumber)}}vs merge-base of <span class="mono">{{.DiffBase}}</span> · {{end}}
  {{with .DiffReview}}{{len .Files}} files changed
  {{if .TotalAdds}} <span class="rv-tadd">+{{.TotalAdds}}</span>{{end}}
  {{if .TotalDels}} <span class="rv-tdel">−{{.TotalDels}}</span>{{end}}
  {{end}}
</p>
{{if .Error}}<div class="flash err">{{.Error}}</div>{{end}}

{{template "diff_review" .}}
{{end}}
