{{define "content"}}
<h1 id="page-dashboard">Dashboard</h1>
<p class="sub">Live operational status of the Grok Work bridge.</p>

{{/* hx-target/hx-select override shell boost (#live-root) so SSE partials swap into the region, not wipe the page. */}}
<div class="live-region"
     id="live-dashboard-stats"
     hx-get="{{route "partial.dashboard.stats"}}"
     hx-trigger="sse:dashboard"
     hx-target="this"
     hx-select="unset"
     hx-swap="innerHTML"
     hx-sync="this:replace">
  {{template "dashboard_stats" .}}
</div>

<div class="section">
  <h2>Active runs</h2>
  <div class="live-region"
       id="live-dashboard-runs"
       hx-get="{{route "partial.dashboard.runs"}}"
       hx-trigger="sse:dashboard"
       hx-target="this"
       hx-select="unset"
       hx-swap="innerHTML"
       hx-sync="this:replace">
    {{template "dashboard_runs" .}}
  </div>
</div>
{{end}}

{{define "dashboard_stats"}}
<div class="grid" id="stats">
  <div class="card">
    <div class="label">Active runs</div>
    <div class="value" id="stat-active">{{.Status.ActiveCount}}</div>
    <div class="hint">{{if gt .Status.ActiveCount 0}}<span class="badge live">running</span>{{else}}idle{{end}}</div>
  </div>
  <div class="card">
    <div class="label">Queued</div>
    <div class="value" id="stat-queued">{{.Status.QueuedTotal}}</div>
    <div class="hint">follow-ups waiting</div>
  </div>
  <div class="card">
    <div class="label">Sessions</div>
    <div class="value" id="stat-sessions">{{.Status.SessionCount}}</div>
    <div class="hint"><a href="{{route "sessions"}}">all work units</a></div>
  </div>
  <div class="card">
    <div class="label">Projects</div>
    <div class="value" id="stat-projects">{{.Status.ProjectCount}}</div>
    <div class="hint">{{if .Status.EmptyMemberProjects}}{{.Status.EmptyMemberProjects}} without members{{else}}all have members{{end}}</div>
  </div>
</div>
{{end}}

{{define "dashboard_runs"}}
<div id="runs-wrap">
  {{if .Status.ActiveRuns}}
  <div class="table-scroll">
  <table id="runs-table">
    <thead>
      <tr><th>Thread</th><th>Project</th><th>Elapsed</th><th>Queue</th></tr>
    </thead>
    <tbody id="runs-body">
      {{range .Status.ActiveRuns}}
      <tr>
        <td class="mono"><a class="tid" href="/sessions/{{.ThreadID}}">{{.ThreadID}}</a></td>
        <td>{{.Project}}</td>
        <td class="mono">{{.Elapsed}}</td>
        <td>{{if gt .QueueLen 0}}<span class="badge">{{.QueueLen}} queued</span>{{else}}<span class="muted">—</span>{{end}}</td>
      </tr>
      {{end}}
    </tbody>
  </table>
  </div>
  {{else}}
  <div class="empty" id="runs-empty">No active runs. Tag <span class="mono">@Grok</span> in a mapped Discord channel to start one.</div>
  {{end}}
</div>
{{end}}
