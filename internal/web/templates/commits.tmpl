{{define "content"}}
<h1 id="page-commits-list">{{.Project}} <span class="muted" style="font-weight:500;font-size:0.95rem">· commits</span></h1>
<p class="sub">
  Repo: <span class="mono">{{.ActiveOwner}}/{{.ActiveRepo}}</span>
  · ref <span class="mono">{{.CommitRef}}</span>
</p>
{{if .Flash}}<div class="flash">{{.Flash}}</div>{{end}}
{{if .Error}}<div class="flash err">{{.Error}}</div>{{end}}

<div class="toolbar" id="commits-toolbar">
<form method="get" action="/projects/{{.Project}}/commits" id="commits-filter" style="display:contents">
  <div class="field" style="flex-basis:18rem">
    <label for="repo-pick">Repository</label>
    <select id="repo-pick" name="repo_full" data-autosubmit>
      {{range .RepoCatalog}}
      <option value="{{.Owner}}/{{.Repo}}" {{if and (eq .Owner $.ActiveOwner) (eq .Repo $.ActiveRepo)}}selected{{end}}>{{.Owner}}/{{.Repo}}</option>
      {{end}}
    </select>
    <input type="hidden" name="owner" id="commits-owner" value="{{.ActiveOwner}}">
    <input type="hidden" name="repo" id="commits-repo" value="{{.ActiveRepo}}">
  </div>
  <div class="field">
    <label for="ref">Ref</label>
    <input id="ref" type="text" name="ref" value="{{.CommitRef}}" placeholder="origin/main" class="mono">
  </div>
  <button type="submit" class="btn-secondary">Apply</button>
</form>
<form method="post" action="/projects/{{.Project}}/commits/fetch" id="commits-fetch" hx-boost="false" style="display:contents">
  {{template "csrf" .}}
  <input type="hidden" name="owner" value="{{.ActiveOwner}}">
  <input type="hidden" name="repo" value="{{.ActiveRepo}}">
  <input type="hidden" name="ref" value="{{.CommitRef}}">
  <button type="submit" class="btn-secondary" title="git fetch --all --prune; unshallow if needed">Fetch</button>
</form>
</div>
<script>
(function(){
  var form=document.getElementById('commits-filter');
  if(!form) return;
  var sel=document.getElementById('repo-pick');
  function sync(){
    var p=(sel.value||'/').split('/');
    document.getElementById('commits-owner').value=p[0]||'';
    document.getElementById('commits-repo').value=p[1]||'';
  }
  sel.addEventListener('change', sync);
  form.addEventListener('submit', sync);
  sync();
})();
</script>
{{if not .RepoCatalog}}
<p class="sub">No repos in catalog. Set <span class="mono">projects.{{.Project}}.github.repos</span> on Config, or ensure git remotes exist.</p>
{{end}}

<div class="section">
  {{if .Commits}}
  <div class="table-scroll">
  <table>
    <thead><tr><th>SHA</th><th>Subject</th><th>Author</th><th>Date</th></tr></thead>
    <tbody>
    {{range .Commits}}
      <tr>
        <td class="mono"><a href="/projects/{{$.Project}}/commits/{{.SHA}}?owner={{urlquery $.ActiveOwner}}&amp;repo={{urlquery $.ActiveRepo}}">{{.ShortSHA}}</a></td>
        <td><a class="pr-title" href="/projects/{{$.Project}}/commits/{{.SHA}}?owner={{urlquery $.ActiveOwner}}&amp;repo={{urlquery $.ActiveRepo}}">{{.Subject}}</a></td>
        <td>{{.AuthorName}}</td>
        <td class="mono">{{if not .AuthorDate.IsZero}}{{.AuthorDate.Format "2006-01-02 15:04"}}{{end}}</td>
      </tr>
    {{end}}
    </tbody>
  </table>
  </div>
  {{else if not .Error}}
  <div class="empty">No commits for this ref.</div>
  {{end}}
  {{if or .CommitHasPrev .CommitHasNext}}
  <nav class="pager" aria-label="Commits pagination">
    <p class="pager-readout">
      {{if .CommitRangeEnd}}commits <span class="pager-num mono">{{.CommitRangeStart}}–{{.CommitRangeEnd}}</span>
      <span class="pager-dot" aria-hidden="true">·</span>
      {{end}}page <span class="pager-num mono">{{.CommitPage}}</span>
    </p>
    <div class="pager-nav">
      {{if .CommitHasPrev}}
      <a class="pager-link" data-pager-prev rel="prev" href="/projects/{{.Project}}/commits?owner={{urlquery .ActiveOwner}}&amp;repo={{urlquery .ActiveRepo}}&amp;ref={{urlquery .CommitRef}}&amp;page={{add .CommitPage -1}}" title="Newer commits (←)">
        <span class="pager-chevron" aria-hidden="true">‹</span> Newer
      </a>
      {{else}}
      <span class="pager-link is-disabled" aria-disabled="true">
        <span class="pager-chevron" aria-hidden="true">‹</span> Newer
      </span>
      {{end}}
      {{if .CommitHasNext}}
      <a class="pager-link" data-pager-next rel="next" href="/projects/{{.Project}}/commits?owner={{urlquery .ActiveOwner}}&amp;repo={{urlquery .ActiveRepo}}&amp;ref={{urlquery .CommitRef}}&amp;page={{add .CommitPage 1}}" title="Older commits (→)">
        Older <span class="pager-chevron" aria-hidden="true">›</span>
      </a>
      {{else}}
      <span class="pager-link is-disabled" aria-disabled="true">
        Older <span class="pager-chevron" aria-hidden="true">›</span>
      </span>
      {{end}}
    </div>
  </nav>
  {{end}}
</div>
{{end}}
