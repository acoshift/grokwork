        if (window.IntersectionObserver) {
          spy = new IntersectionObserver(function (entries) {
            for (var i = 0; i < entries.length; i++) {
              if (entries[i].isIntersecting) {
                setCurrent(r, entries[i].target, false);
                break;
              }
            }
          }, { rootMargin: "-15% 0px -70% 0px" });
          cards(r).forEach(function (c) { spy.observe(c); });
        }
      }

      document.addEventListener("click", function (e) {
        var r = root();
        if (!r || !e.target.closest) return;
        var fold = e.target.closest("[data-rv-fold]");
        if (fold && r.contains(fold)) {
          fold.closest(".fcard").classList.toggle("folded");
          return;
        }
        var row = e.target.closest("[data-rv-row]");
        if (row && r.contains(row)) {
          var card = document.getElementById("df-" + row.getAttribute("data-rv-row"));
          if (card) setCurrent(r, card, true);
          return;
        }
        if (e.target.closest("[data-rv-expand]")) {
          cards(r).forEach(function (card) {
            card.classList.remove("folded");
            if (!card.hasAttribute("data-gen")) loadCard(card);
          });
          return;
        }
        if (e.target.closest("[data-rv-collapse]")) {
          cards(r).forEach(function (card) { card.classList.add("folded"); });
        }
      });

      document.addEventListener("change", function (e) {
        var r = root();
        if (!r || !e.target.matches || !e.target.matches("[data-rv-viewed]")) return;
        setViewed(r, e.target.closest(".fcard"), e.target.checked);
      });

      var filterTimer = 0;
      document.addEventListener("input", function (e) {
        var r = root();
        if (!r || !e.target.matches || !e.target.matches("[data-rv-filter]")) return;
        var q = e.target.value.trim().toLowerCase();
        clearTimeout(filterTimer);
        filterTimer = setTimeout(function () {
          cards(r).forEach(function (card) {
            var hit = !q || (card.getAttribute("data-path") || "").toLowerCase().indexOf(q) >= 0;
            card.style.display = hit ? "" : "none";
            var row = railRow(r, card.getAttribute("data-rv-card"));
            if (row) row.style.display = hit ? "" : "none";
          });
          r.querySelectorAll(".rgroup").forEach(function (g) {
            var any = Array.prototype.some.call(g.querySelectorAll(".rrow"), function (row) {
              return row.style.display !== "none";
            });
            g.style.display = any ? "" : "none";
          });
        }, 80);
      });

      document.addEventListener("keydown", function (e) {
        var r = root();
        if (!r) return;
        var t = e.target;
        if (t instanceof Element && t.matches("input, textarea, select")) {
          if (e.key === "Escape") t.blur();
          return;
        }
        if (e.metaKey || e.ctrlKey || e.altKey) return;
        if (e.key === "/") {
          var f = r.querySelector("[data-rv-filter]");
          if (f) { e.preventDefault(); f.focus(); }
          return;
        }
        var vis = visibleCards(r);
        if (!vis.length) return;
        var pos = -1;
        for (var i = 0; i < vis.length; i++) {
          if (parseInt(vis[i].getAttribute("data-rv-card"), 10) === currentIdx) { pos = i; break; }
        }
        function go(card) {
          setCurrent(r, card, true);
          card.scrollIntoView({ block: "start" });
        }
        if (e.key === "j" || e.key === "k") {
          e.preventDefault();
          go(vis[e.key === "j" ? Math.min(pos + 1, vis.length - 1) : Math.max(pos - 1, 0)]);
        } else if (e.key === "v" && pos >= 0) {
          var cur = vis[pos];
          var on = !cur.classList.contains("is-viewed");
          setViewed(r, cur, on);
          if (on && pos < vis.length - 1) go(vis[pos + 1]);
        } else if (e.key === "o" && pos >= 0) {
          vis[pos].classList.toggle("folded");
        }
      });

      document.body.addEventListener("htmx:afterSettle", function (e) {
        var elt = e.detail && e.detail.elt;
        if (elt && elt.id === "live-root") setup();
      });
      document.body.addEventListener("htmx:historyRestore", setup);
      setup();
    })();
  })();
  </script>
</body>
</html>
