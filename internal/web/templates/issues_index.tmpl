{{define "content"}}
<h1 id="page-issues">Issues</h1>
<p class="sub">Pick a project to browse GitHub issues (multi-repo picker on the project page). Linear links appear when enabled.</p>
{{if .Error}}<div class="flash err">{{.Error}}</div>{{end}}
<div class="section">
  {{if .Config.ProjectNames}}
  <div class="table-scroll">
  <table>
    <thead><tr><th>Project</th><th>GitHub issues</th><th>Linear</th></tr></thead>
    <tbody>
    {{range .Config.Projects}}
      <tr>
        <td class="mono">{{.Name}}</td>
        <td><a href="/projects/{{.Name}}/issues">Open issues</a></td>
        <td>
          {{if .LinearEnabled}}
            <a href="/projects/{{.Name}}/linear">Linear ({{.LinearTeamKey}})</a>
          {{else}}
            <span class="muted">—</span>
          {{end}}
        </td>
      </tr>
    {{end}}
    </tbody>
  </table>
  </div>
  {{else}}
  <div class="empty">No projects configured.</div>
  {{end}}
</div>
{{end}}
