{{define "content"}}
<h1 id="page-config">Config</h1>
<p class="sub">Manage projects, channel map, and allowlists. Changes persist to the config file and apply immediately.</p>

{{if .Flash}}
<div class="flash">{{.Flash}}</div>
{{end}}
{{if .Error}}
<div class="flash err">{{.Error}}</div>
{{end}}

<div class="section card" id="bot-invite">
  <h2>Bot install / permission update URL</h2>
  <p class="sub" style="margin-top:0">
    Invite this bot or <strong>re-authorize</strong> it on a server already joined so the role picks up the current permission set.
    Required: View Channel, Send Messages, Manage Messages, <strong>Pin Messages</strong> (continuity brief card), Attach Files, Read Message History, Create Public Threads, Send Messages in Threads.
  </p>
  {{if .Config.InviteURL}}
  <div class="invite-row">
    <input id="invite-url" type="text" readonly value="{{.Config.InviteURL}}" onclick="this.select()">
    <button type="button" class="btn btn-secondary" data-copy-target="invite-url">Copy</button>
    <a class="btn btn-secondary" href="{{.Config.InviteURL}}" target="_blank" rel="noopener noreferrer">Open / re-authorize</a>
  </div>
  <p class="sub" style="margin:0.65rem 0 0">
    Client ID: <span class="mono">{{.Config.ClientID}}</span>
    · permissions <span class="mono">{{.Config.InvitePermissions}}</span>
    · scope <span class="mono">bot</span>
  </p>
  <p class="sub" style="margin:0.35rem 0 0">
    Changing the URL alone does not upgrade an already-joined bot — open the link above, pick the server, and approve again.
    Brief pin failures (<span class="mono">Missing Permissions</span> / code <span class="mono">50013</span>) mean <strong>Pin Messages</strong> is still missing on the bot role (Discord split this from Manage Messages).
  </p>
  <p class="sub" style="margin:0.35rem 0 0">Also enable <strong>Message Content Intent</strong> in the Developer Portal (Bot → Privileged Gateway Intents).</p>
  {{else}}
  <div class="flash err" style="margin:0">Could not build install URL{{if .Config.InviteError}}: {{.Config.InviteError}}{{end}}. Set a valid <span class="mono">discordToken</span> or <span class="mono">discordClientId</span> in config.json.</div>
  {{end}}
</div>

<div class="section card" id="grok-run-limits">
  <h2>Grok run limits</h2>
  <p class="sub" style="margin-top:0">
    Per Discord task: <span class="mono">maxTurns</span> is the tool/turn budget for
    <span class="mono">grok -p</span>; <span class="mono">timeoutMs</span> kills the process after that many milliseconds.
    Defaults are <span class="mono">40</span> turns and <span class="mono">1800000</span> ms (30 minutes). Applies to new runs only.
  </p>
  <form class="inline" method="post" action="{{route "config.settings"}}" style="grid-template-columns: 1fr 1fr auto;">
    {{template "csrf" $}}
    <input type="hidden" name="section" value="run">
    <div>
      <label for="max-turns">Max turns</label>
      <input id="max-turns" type="number" name="maxTurns" min="1" step="1" required value="{{.Config.MaxTurns}}" autocomplete="off">
    </div>
    <div>
      <label for="timeout-ms">Timeout (ms)</label>
      {{/* min=1000 and step=1: min=1+step=1000 made default 1800000 fail HTML5 validation. */}}
      <input id="timeout-ms" type="number" name="timeoutMs" min="1000" max="86400000" step="1" required value="{{.Config.TimeoutMs}}" autocomplete="off" title="1000–86400000 ms (1 second–24 hours)">
    </div>
    <button type="submit">Save</button>
  </form>
  <p class="sub" style="margin:0.5rem 0 0">Range: 1 s–24 h. Examples: 15 min = <span class="mono">900000</span>, 30 min = <span class="mono">1800000</span>, 1 h = <span class="mono">3600000</span>.</p>
</div>

<div class="section card">
  <h2>Worktree idle cleanup</h2>
  <p class="sub" style="margin-top:0">Prune per-thread git worktrees after this many days without activity. <span class="mono">0</span> disables automatic cleanup. Default is <span class="mono">30</span>.</p>
  <form class="inline" method="post" action="{{route "config.settings"}}" style="grid-template-columns: 1fr auto;">
    {{template "csrf" $}}
    <input type="hidden" name="section" value="worktree">
    <div>
      <label for="worktree-idle-ttl">Idle TTL (days)</label>
      <input id="worktree-idle-ttl" type="number" name="worktreeIdleTTLDays" min="0" step="1" required value="{{.Config.WorktreeIdleTTLDays}}" autocomplete="off">
    </div>
    <button type="submit">Save</button>
  </form>
</div>

<div class="section card" id="team-board">
  <h2>Team activity board</h2>
  <p class="sub" style="margin-top:0">
    <span class="mono">@Grok /board</span> groups threads by activity (running, queued, waiting on human, stale).
    Stale is based on session inactivity. Optional nightly digest posts the board into a Discord channel.
  </p>
  <form class="inline" method="post" action="{{route "config.settings"}}" style="grid-template-columns: 1fr 2fr auto;">
    {{template "csrf" $}}
    <input type="hidden" name="section" value="board">
    <div>
      <label for="board-stale-days">Stale after (days)</label>
      <input id="board-stale-days" type="number" name="boardStaleDays" min="1" step="1" required value="{{.Config.BoardStaleDays}}" autocomplete="off">
    </div>
    <div>
      <label for="board-digest-channel">Nightly digest channel ID</label>
      <input id="board-digest-channel" type="text" name="boardDigestChannel" value="{{.Config.BoardDigestChannel}}" placeholder="optional Discord channel ID" autocomplete="off">
    </div>
    <button type="submit">Save</button>
  </form>
  <p class="sub" style="margin:0.5rem 0 0">Default stale threshold is <span class="mono">3</span> days. Leave the channel empty to disable the digest.</p>
</div>

<div class="section card" id="ci-triage">
  <h2>CI triage</h2>
  <p class="sub" style="margin-top:0">
    When a thread’s PR has failing checks, the bot posts a digest and offers <span class="mono">@Grok /fix-ci</span>.
    Optionally auto-queue a fix (default off). Cap is per Discord thread session.
  </p>
  <form class="inline" method="post" action="{{route "config.settings"}}" style="grid-template-columns: auto 1fr auto;">
    {{template "csrf" $}}
    <input type="hidden" name="section" value="ci">
    <div>
      <label class="check">
        <input type="checkbox" name="autoFixCI" value="1" {{if .Config.AutoFixCI}}checked{{end}}>
        Auto-queue CI fix
      </label>
    </div>
    <div>
      <label for="auto-fix-ci-max">Max auto attempts</label>
      <input id="auto-fix-ci-max" type="number" name="autoFixCIMax" min="1" step="1" required value="{{.Config.AutoFixCIMax}}" autocomplete="off">
    </div>
    <button type="submit">Save</button>
  </form>
  <p class="sub" style="margin:0.5rem 0 0">Max is per Discord thread session (default 2). Manual <span class="mono">/fix-ci</span> is always available.</p>
</div>

<div class="section card" id="risky-paths">
  <h2>Completion risk paths</h2>
  <p class="sub" style="margin-top:0">
    Globs that flag paths on the completion summary card (migrations, auth, deploy, …).
    One pattern per line; <span class="mono">**</span> and <span class="mono">*</span> supported. Lines starting with <span class="mono">#</span> are comments.
  </p>
  <form method="post" action="{{route "config.settings"}}">
    {{template "csrf" $}}
    <input type="hidden" name="section" value="risky">
    <div style="margin-bottom: 0.65rem;">
      <label class="check">
        <input type="checkbox" name="riskyPathUseDefault" value="1" id="risky-use-default" {{if .Config.RiskyPathUseDefault}}checked{{end}}>
        Use built-in defaults
      </label>
    </div>
    <div>
      <label for="risky-globs">Globs</label>
      <textarea id="risky-globs" name="riskyPathGlobs" rows="8" placeholder="**/migrations/**&#10;**/auth/**&#10;**/.env*" {{if .Config.RiskyPathUseDefault}}readonly{{end}}>{{.Config.RiskyPathGlobsText}}</textarea>
    </div>
    <p class="sub" style="margin:0.5rem 0 0">
      With defaults checked, the list is shown read-only (not stored as a custom override).
      Uncheck defaults to edit; clear the box entirely to disable risk highlighting.
    </p>
    <div class="form-actions">
      <button type="submit">Save</button>
    </div>
  </form>
</div>

<div class="section card">
  <h2>Add project folder</h2>
  <form class="inline" method="post" action="{{route "config.addProject"}}">
    {{template "csrf" $}}
    <div>
      <label for="proj-name">Name</label>
      <input id="proj-name" type="text" name="name" placeholder="myapp" required autocomplete="off">
    </div>
    <div>
      <label for="proj-path">Absolute path</label>
      <input id="proj-path" type="text" name="path" placeholder="/absolute/path/to/repo" required autocomplete="off">
    </div>
    <button type="submit">Add folder</button>
  </form>
</div>

<div class="section card">
  <h2>Default Discord guild (fallback)</h2>
  <p class="sub" style="margin-top:0">
    Used only when a project has no guild of its own. Prefer setting the guild on each project below for multi-server setups.
  </p>
  <form class="inline" method="post" action="{{route "config.setGuild"}}" style="grid-template-columns: 1fr auto;">
    {{template "csrf" $}}
    <div>
      <label for="guild-id">Default guild ID</label>
      <input id="guild-id" type="text" name="discordGuildId" value="{{.Config.DiscordGuildID}}" placeholder="optional fallback" autocomplete="off">
    </div>
    <button type="submit">Save default guild</button>
  </form>
</div>

<div class="section card">
  <h2>GitHub repos &amp; Discord (per project)</h2>
  <p class="sub" style="margin:0 0 0.75rem">
    Multi-repo catalog (one <span class="mono">owner/repo</span> per line). Leave repos blank to discover from git remotes.
    Preferred channel must already be mapped to the project in Channels.
    Set each project’s <strong>Discord guild ID</strong> so “Open in Discord” links the right server (multi-guild).
  </p>
  {{range .Config.Projects}}
  <div style="border-top:1px solid var(--border);padding:0.85rem 0;">
    <div class="mono" style="font-weight:600;margin-bottom:0.5rem;">{{.Name}}</div>
    <form method="post" action="{{route "config.setProjectGitHub"}}" style="margin-bottom:0.65rem;">
      {{template "csrf" $}}
      <input type="hidden" name="name" value="{{.Name}}">
      <label for="repos-{{.Name}}">GitHub repos</label>
      <textarea id="repos-{{.Name}}" name="repos" rows="3" placeholder="acme/app&#10;acme/api">{{.GitHubReposText}}</textarea>
      <div class="form-actions"><button type="submit">Save repos</button></div>
    </form>
    <form class="inline" method="post" action="{{route "config.setProjectChannel"}}" style="grid-template-columns: 1fr 1fr auto; align-items: end;">
      {{template "csrf" $}}
      <input type="hidden" name="name" value="{{.Name}}">
      <div>
        <label for="ch-{{.Name}}">Preferred Discord channel</label>
        <select id="ch-{{.Name}}" name="channelId">
          <option value="">(auto / reverse-map)</option>
          {{$pref := .DiscordChannelID}}
          {{range .ChannelOptions}}
          <option value="{{.}}" {{if eq . $pref}}selected{{end}}>{{.}}</option>
          {{end}}
        </select>
      </div>
      <div>
        <label for="guild-{{.Name}}">Discord guild ID</label>
        <input id="guild-{{.Name}}" type="text" name="guildId" value="{{.DiscordGuildID}}" placeholder="server snowflake" autocomplete="off">
      </div>
      <button type="submit">Save Discord</button>
    </form>
  </div>
  {{else}}
  <p class="sub">Add a project first.</p>
  {{end}}
</div>

<div class="section card">
  <h2>Linear (per project)</h2>
  <p class="sub" style="margin:0 0 0.75rem">Opt-in ticket binding. API key is per project (different Linear workspaces allowed). Empty API key field leaves the stored key unchanged. Env alternative: <span class="mono">LINEAR_API_KEY_&lt;PROJECT&gt;</span>.</p>
  <form class="inline" method="post" action="{{route "config.setProjectLinear"}}" style="grid-template-columns: 1fr 1fr 1fr 1fr auto; align-items: end;">
    {{template "csrf" $}}
    <div>
      <label for="lin-project">Project</label>
      <select id="lin-project" name="name" required>
        <option value="" disabled selected>Select…</option>
        {{range .Config.ProjectNames}}
        <option value="{{.}}">{{.}}</option>
        {{end}}
      </select>
    </div>
    <div>
      <label for="lin-team">Team key</label>
      <input id="lin-team" type="text" name="teamKey" placeholder="ENG" autocomplete="off">
    </div>
    <div>
      <label for="lin-key">API key</label>
      <input id="lin-key" type="password" name="apiKey" placeholder="leave blank to keep" autocomplete="off">
    </div>
    <div>
      <label><input type="checkbox" name="enabled" value="1"> Enabled</label>
      <label style="display:block;margin-top:0.35rem"><input type="checkbox" name="clearApiKey" value="1"> Clear API key</label>
    </div>
    <button type="submit">Save Linear</button>
  </form>
  {{if not .Config.ProjectNames}}
  <p class="sub" style="margin:0.5rem 0 0">Add a project first.</p>
  {{end}}
</div>

<div class="section card">
  <h2>Add channel map</h2>
  <form class="inline" method="post" action="{{route "config.addChannel"}}">
    {{template "csrf" $}}
    <div>
      <label for="channel-id">Discord channel ID</label>
      <input id="channel-id" type="text" name="channelId" placeholder="123456789012345678" required autocomplete="off">
    </div>
    <div>
      <label for="channel-project">Project</label>
      <select id="channel-project" name="project" required>
        <option value="" disabled selected>Select project…</option>
        {{range .Config.ProjectNames}}
        <option value="{{.}}">{{.}}</option>
        {{end}}
      </select>
    </div>
    <button type="submit">Add channel</button>
  </form>
  {{if not .Config.ProjectNames}}
  <p class="sub" style="margin:0.5rem 0 0">Add a project first, then map a channel to it.</p>
  {{end}}
</div>

<div class="section card">
  <h2>Add allowed user</h2>
  <form class="inline" method="post" action="{{route "config.addUser"}}" style="grid-template-columns: 1fr auto;">
    {{template "csrf" $}}
    <div>
      <label for="user-id">Discord user ID</label>
      <input id="user-id" type="text" name="id" placeholder="123456789012345678" required autocomplete="off">
    </div>
    <button type="submit">Add user</button>
  </form>
</div>

<div class="section card">
  <h2>Add allowed role</h2>
  <form class="inline" method="post" action="{{route "config.addRole"}}" style="grid-template-columns: 1fr auto;">
    {{template "csrf" $}}
    <div>
      <label for="role-id">Discord role ID</label>
      <input id="role-id" type="text" name="id" placeholder="123456789012345678" required autocomplete="off">
    </div>
    <button type="submit">Add role</button>
  </form>
</div>

{{/* hx-target/hx-select override shell boost (#live-root) so SSE partials swap into the region, not wipe the page. */}}
<div class="live-region"
     id="live-config-lists"
     hx-get="{{route "partial.config.lists"}}"
     hx-trigger="sse:config"
     hx-target="this"
     hx-select="unset"
     hx-swap="innerHTML"
     hx-sync="this:replace">
  {{template "config_lists" .}}
</div>
{{end}}

{{define "config_lists"}}
<div class="section">
  <h2>Projects</h2>
  {{if .Config.Projects}}
  <div class="table-scroll">
  <table>
    <thead><tr><th>Name</th><th>Path</th><th>Linear</th><th></th></tr></thead>
    <tbody>
      {{range .Config.Projects}}
      <tr>
        <td class="mono">{{.Name}}</td>
        <td class="mono">{{.Path}}</td>
        <td class="mono">
          {{if .LinearEnabled}}
            on{{if .LinearTeamKey}} · {{.LinearTeamKey}}{{end}}{{if .LinearAPIKeySet}} · key set{{else}} · no key{{end}}
          {{else}}
            off
          {{end}}
        </td>
        <td class="row-actions">
          <form method="post" action="{{route "config.removeProject"}}" onsubmit="return confirm('Remove project {{.Name}}? Channel maps to this project will also be removed.');">
    {{template "csrf" $}}
            <input type="hidden" name="name" value="{{.Name}}">
            <button type="submit" class="btn-danger">Remove</button>
          </form>
        </td>
      </tr>
      {{end}}
    </tbody>
  </table>
  </div>
  {{else}}
  <div class="empty">No projects configured.</div>
  {{end}}
</div>

<div class="section">
  <h2>Channel map</h2>
  {{if .Config.Channels}}
  <div class="table-scroll">
  <table>
    <thead><tr><th>Channel ID</th><th>Project</th><th></th></tr></thead>
    <tbody>
      {{range .Config.Channels}}
      <tr>
        <td class="mono">{{.ChannelID}}</td>
        <td>{{.Project}}</td>
        <td class="row-actions">
          <form method="post" action="{{route "config.removeChannel"}}" onsubmit="return confirm('Remove channel {{.ChannelID}}?');">
    {{template "csrf" $}}
            <input type="hidden" name="channelId" value="{{.ChannelID}}">
            <button type="submit" class="btn-danger">Remove</button>
          </form>
        </td>
      </tr>
      {{end}}
    </tbody>
  </table>
  </div>
  {{else}}
  <div class="empty">No channels mapped.</div>
  {{end}}
</div>

<div class="section">
  <h2>Allowed users</h2>
  {{if .Config.AllowedUserIDs}}
  <div class="table-scroll">
  <table>
    <thead><tr><th>User ID</th><th></th></tr></thead>
    <tbody>
      {{range .Config.AllowedUserIDs}}
      <tr>
        <td class="mono">{{.}}</td>
        <td class="row-actions">
          <form method="post" action="{{route "config.removeUser"}}" onsubmit="return confirm('Remove user {{.}}?');">
    {{template "csrf" $}}
            <input type="hidden" name="id" value="{{.}}">
            <button type="submit" class="btn-danger">Remove</button>
          </form>
        </td>
      </tr>
      {{end}}
    </tbody>
  </table>
  </div>
  {{else}}
  <div class="empty">No allowed users.</div>
  {{end}}
</div>

<div class="section">
  <h2>Allowed roles</h2>
  {{if .Config.AllowedRoleIDs}}
  <div class="table-scroll">
  <table>
    <thead><tr><th>Role ID</th><th></th></tr></thead>
    <tbody>
      {{range .Config.AllowedRoleIDs}}
      <tr>
        <td class="mono">{{.}}</td>
        <td class="row-actions">
          <form method="post" action="{{route "config.removeRole"}}" onsubmit="return confirm('Remove role {{.}}?');">
    {{template "csrf" $}}
            <input type="hidden" name="id" value="{{.}}">
            <button type="submit" class="btn-danger">Remove</button>
          </form>
        </td>
      </tr>
      {{end}}
    </tbody>
  </table>
  </div>
  {{else}}
  <div class="empty">No allowed roles.</div>
  {{end}}
</div>
{{end}}
