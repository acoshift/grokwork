{{define "content"}}
<h1 id="page-ship">Ship board</h1>
<p class="sub">All bot-tracked pull requests for leads — filter by project and state. Status comes from the session store (updated by the Discord PR poller), not a live <span class="mono">gh</span> call.</p>

{{/* hx-target/hx-select override shell boost (#live-root) so SSE partials swap into the region, not wipe the page. */}}
<div class="live-region"
     id="live-ship-stats"
     hx-get="{{route "partial.ship.stats"}}?project={{urlquery .Ship.ProjectFilter}}&amp;state={{urlquery .Ship.StateFilter}}"
     hx-trigger="sse:ship"
     hx-target="this"
     hx-select="unset"
     hx-swap="innerHTML"
     hx-sync="this:replace">
  {{template "ship_stats" .}}
</div>

<form method="get" action="{{route "ship"}}" class="toolbar" id="ship-filters">
  <div class="field">
    <label for="project">Project</label>
    <select id="project" name="project" data-autosubmit>
      <option value="" {{if eq .Ship.ProjectFilter ""}}selected{{end}}>All projects</option>
      {{range .Ship.Projects}}
      <option value="{{.}}" {{if eq $.Ship.ProjectFilter .}}selected{{end}}>{{.}}</option>
      {{end}}
    </select>
  </div>
  <div class="field">
    <label for="state">State</label>
    <select id="state" name="state" data-autosubmit>
      <option value="open" {{if eq .Ship.StateFilter "open"}}selected{{end}}>Open (default)</option>
      <option value="failing" {{if eq .Ship.StateFilter "failing"}}selected{{end}}>CI failing</option>
      <option value="draft" {{if eq .Ship.StateFilter "draft"}}selected{{end}}>Draft</option>
      <option value="merged" {{if eq .Ship.StateFilter "merged"}}selected{{end}}>Merged</option>
      <option value="closed" {{if eq .Ship.StateFilter "closed"}}selected{{end}}>Closed</option>
      <option value="all" {{if eq .Ship.StateFilter "all"}}selected{{end}}>All</option>
    </select>
  </div>
  <button type="submit" class="btn-secondary">Apply</button>
</form>

<div class="live-region"
     id="live-ship-table"
     hx-get="{{route "partial.ship.table"}}?project={{urlquery .Ship.ProjectFilter}}&amp;state={{urlquery .Ship.StateFilter}}"
     hx-trigger="sse:ship"
     hx-target="this"
     hx-select="unset"
     hx-swap="innerHTML"
     hx-sync="this:replace">
  {{template "ship_table" .}}
</div>
{{end}}

{{define "ship_stats"}}
<div class="grid">
  <div class="card">
    <div class="label">Open</div>
    <div class="value">{{.Ship.Open}}</div>
    <div class="hint">{{.Ship.Draft}} draft</div>
  </div>
  <div class="card">
    <div class="label">CI failing</div>
    <div class="value">{{.Ship.ChecksFailing}}</div>
    <div class="hint">{{if gt .Ship.ChecksFailing 0}}<span class="badge status-error">needs attention</span>{{else}}all green{{end}}</div>
  </div>
  <div class="card">
    <div class="label">Changes requested</div>
    <div class="value">{{.Ship.ChangesRequested}}</div>
    <div class="hint">waiting on Grok or owner</div>
  </div>
  <div class="card">
    <div class="label">Approved</div>
    <div class="value">{{.Ship.Approved}}</div>
    <div class="hint">merged {{.Ship.Merged}} · closed {{.Ship.Closed}}</div>
  </div>
</div>
{{end}}

{{define "ship_table"}}
<div class="section">
  <h2>Pull requests <span class="muted" style="font-weight:500;font-size:0.9rem">({{len .Ship.Rows}} shown · {{.Ship.Total}} tracked{{if .Ship.ProjectFilter}} in {{.Ship.ProjectFilter}}{{end}})</span></h2>
  {{if .Ship.Rows}}
  <div class="table-scroll">
  <table>
    <thead>
      <tr>
        <th>PR</th>
        <th>State</th>
        <th>Checks</th>
        <th>Review</th>
        <th>Project</th>
        <th>Owner</th>
        <th>Label</th>
        <th>Thread</th>
      </tr>
    </thead>
    <tbody>
      {{range .Ship.Rows}}
      <tr>
        <td class="pr-cell">
          {{if and .GHOwner .GHRepo .Number}}
          <a class="pr-title" href="/prs/{{.GHOwner}}/{{.GHRepo}}/{{.Number}}?project={{urlquery .Project}}">{{if .Title}}{{.Title}}{{else if .Goal}}{{.Goal}}{{else}}{{.GHOwner}}/{{.GHRepo}}#{{.Number}}{{end}}</a>
          <div class="pr-ref mono">{{.GHOwner}}/{{.GHRepo}}#{{.Number}}{{if .URL}} <a href="{{.URL}}" target="_blank" rel="noopener" title="Open on GitHub">↗</a>{{end}}</div>
          {{else if .URL}}
          <a class="pr-title" href="{{.URL}}" target="_blank" rel="noopener">{{if .Title}}{{.Title}}{{else if .Number}}#{{.Number}}{{else}}PR{{end}}</a>
          {{if .Goal}}<div class="pr-ref">{{.Goal}}</div>{{end}}
          {{else}}
          <span class="mono">{{if .Number}}#{{.Number}}{{else}}—{{end}}</span>
          {{if .Title}}<div class="pr-ref">{{.Title}}</div>{{else if .Goal}}<div class="pr-ref">{{.Goal}}</div>{{end}}
          {{end}}
        </td>
        <td>
          {{if eq .State "OPEN"}}
          <span class="badge live">{{.State}}</span>
          {{else if eq .State "DRAFT"}}
          <span class="badge">{{.State}}</span>
          {{else if eq .State "MERGED"}}
          <span class="badge status-merged">{{.State}}</span>
          {{else if eq .State "CLOSED"}}
          <span class="badge status-cancelled">{{.State}}</span>
          {{else}}
          <span class="badge">{{.State}}</span>
          {{end}}
          {{if .Running}} <span class="badge live">running</span>{{end}}
          {{if gt .Queue 0}} <span class="badge">queue {{.Queue}}</span>{{end}}
        </td>
        <td class="mono">
          {{if .ChecksFailing}}
          <span class="badge status-error">{{if .Checks}}{{.Checks}}{{else}}failing{{end}}</span>
          {{else if .Checks}}
          {{.Checks}}
          {{else}}
          <span class="muted">—</span>
          {{end}}
        </td>
        <td>
          {{if .ChangesRequested}}
          <span class="badge status-warn">{{if .Review}}{{.Review}}{{else}}CHANGES_REQUESTED{{end}}</span>
          {{else if .ReviewApproved}}
          <span class="badge status-done">{{if .Review}}{{.Review}}{{else}}APPROVED{{end}}</span>
          {{else if .Review}}
          {{.Review}}
          {{else}}
          <span class="muted">—</span>
          {{end}}
        </td>
        <td>{{if .Project}}{{.Project}}{{else}}<span class="muted">—</span>{{end}}</td>
        <td>{{if .OwnerName}}{{.OwnerName}}{{else if .OwnerID}}<span class="mono">{{.OwnerID}}</span>{{else}}<span class="muted">—</span>{{end}}</td>
        <td>
          <span class="badge">{{.Label}}</span>
          {{if .LabelManual}} <span class="muted" style="font-size:0.75rem;">manual</span>{{end}}
        </td>
        <td class="mono"><a class="tid" href="/sessions/{{.ThreadID}}">{{.ThreadID}}</a></td>
      </tr>
      {{end}}
    </tbody>
  </table>
  </div>
  {{else}}
  <div class="empty">
    {{if eq .Ship.Total 0}}
    No bot-tracked PRs{{if .Ship.ProjectFilter}} for <span class="mono">{{.Ship.ProjectFilter}}</span>{{end}}. PRs appear after Grok opens or links one in a thread.
    {{else}}
    No PRs match this filter ({{.Ship.Total}} tracked{{if .Ship.ProjectFilter}} in {{.Ship.ProjectFilter}}{{end}}).
    {{end}}
  </div>
  {{end}}
</div>
{{end}}
