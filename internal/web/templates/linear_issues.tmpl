{{define "content"}}
<h1 id="page-linear-list">Linear · {{.Project}}</h1>
<p class="sub">Team <span class="mono">{{.LinearTeam}}</span> · <a href="/projects/{{.Project}}/issues">GitHub issues</a> · <a href="/projects/{{.Project}}">Overview</a></p>
{{if .Error}}<div class="flash err">{{.Error}}</div>{{end}}
<div class="section">
  {{if .LinearIssues}}
  <div class="table-scroll">
  <table>
    <thead><tr><th>ID</th><th>Title</th><th>State</th></tr></thead>
    <tbody>
    {{range .LinearIssues}}
      <tr>
        <td class="mono"><a href="/projects/{{$.Project}}/linear/{{.Identifier}}">{{.Identifier}}</a></td>
        <td><a class="pr-title" href="/projects/{{$.Project}}/linear/{{.Identifier}}">{{.Title}}</a></td>
        <td>
          {{if eq .WorkState "FIXING"}}
          <span class="badge live" title="Active Grok fix session">FIXING</span>
          {{else}}
          <span class="badge">{{.State}}</span>
          {{end}}
        </td>
      </tr>
    {{end}}
    </tbody>
  </table>
  </div>
  {{else}}
  <div class="empty">No Linear issues loaded.</div>
  {{end}}
</div>
{{end}}
