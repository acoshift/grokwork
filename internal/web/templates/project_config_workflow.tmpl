{{define "content"}}
<div id="page-project-config-workflow">
{{template "project_config_header" $}}

<div class="section card" id="project-ship">
  <h2>Shipping</h2>
  <p class="sub" style="margin-top:0">
    How finished session branches reach the repository. Existing threads keep
    their ship mode; changes apply to new threads.
  </p>
  <form method="post" action="{{route "config.setProjectShip"}}">
    {{template "csrf" $}}
    <input type="hidden" name="name" value="{{.ProjectItem.Name}}">
    <div class="choice-row">
      <label class="choice">
        <input type="radio" name="directToPrimary" value="0" {{if not .ProjectItem.DirectToPrimary}}checked{{end}}>
        <span class="dot"></span>
        <span class="t">Pull requests <span class="flag ok">default</span></span>
        <span class="d">Each session works a managed branch and opens a PR for review via <span class="mono">gh</span>.</span>
      </label>
      <label class="choice">
        <input type="radio" name="directToPrimary" value="1" {{if .ProjectItem.DirectToPrimary}}checked{{end}}>
        <span class="dot"></span>
        <span class="t">Direct to primary <span class="flag warn">no review</span></span>
        <span class="d">The bot fast-forwards the project default branch and pushes — no PR. Solo / fast-moving trusted projects only.</span>
      </label>
    </div>
    <div class="form-actions"><button type="submit">Save shipping</button></div>
  </form>
</div>

<div class="section card" id="project-sessions">
  <h2>Sessions</h2>
  <p class="sub" style="margin-top:0">Defaults for new sessions started from Discord or the web.</p>
  <form class="inline" method="post" action="{{route "config.setProjectMode"}}" style="grid-template-columns: minmax(0, 22rem) auto;">
    {{template "csrf" $}}
    <input type="hidden" name="name" value="{{.ProjectItem.Name}}">
    <div>
      <label for="project-default-mode">Default mode</label>
      <select id="project-default-mode" name="defaultMode">
        {{$curMode := .ProjectItem.DefaultMode}}
        <option value="" {{if eq $curMode ""}}selected{{end}}>fix — implement &amp; ship (default)</option>
        <option value="case" {{if eq $curMode "case"}}selected{{end}}>case — support lifecycle</option>
        <option value="investigate" {{if eq $curMode "investigate"}}selected{{end}}>investigate — read-only</option>
        <option value="explain" {{if eq $curMode "explain"}}selected{{end}}>explain</option>
      </select>
    </div>
    <button type="submit">Save mode</button>
  </form>
  <p class="sub" style="margin:0.5rem 0 0">
    Support channels usually want <span class="mono">case</span> so freeform
    messages stay on the case lifecycle. Eng channels keep the default (fix).
  </p>

  <div style="border-top:1px solid var(--border); margin-top:1.1rem; padding-top:1rem;">
    <form method="post" action="{{route "config.setProjectVerify"}}" id="project-verify">
      {{template "csrf" $}}
      <input type="hidden" name="name" value="{{.ProjectItem.Name}}">
      <label for="project-verify-cmds">Verify commands — run by <span class="mono">@Grok /verify</span></label>
      <textarea id="project-verify-cmds" name="verifyCommands" rows="5" placeholder="unit | go test ./...&#10;lint | make lint | 300000" spellcheck="false">{{.ProjectItem.VerifyCommandsText}}</textarea>
      <p class="sub" style="margin:0.4rem 0 0; font-size:0.8rem">
        <span class="mono">name | command | timeoutMs?</span> per line (also <span class="mono">name: command</span>) ·
        runs in the session worktree, no model call · <span class="mono">#</span> comments · empty save clears all.
        <span class="muted">Suggest with Grok</span> inspects the project checkout and fills a draft — Save to apply.
      </p>
      <div class="form-actions">
        <button type="submit">Save verify commands</button>
        <button type="button" class="btn-secondary"
          data-grok-stream
          data-url="{{route "config.generateProjectVerify"}}"
          data-title="Suggest verify commands"
          data-subtitle="Inspecting the project checkout"
          data-fill="#project-verify-cmds"
          data-result-key="text"
          data-auto-close="900"
          title="Inspect the project checkout with Grok and draft verify commands (not saved until you Save)">Suggest with Grok</button>
      </div>
    </form>
  </div>
</div>
</div>
{{end}}
