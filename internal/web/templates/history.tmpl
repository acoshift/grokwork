{{define "content"}}
<h1 id="page-history">History</h1>
{{/* hx-target/hx-select override shell boost (#live-root) so SSE partials swap into the region, not wipe the page. */}}
<div class="live-region"
     id="live-history-table"
     hx-get="{{route "partial.history.table"}}"
     hx-trigger="sse:history"
     hx-target="this"
     hx-select="unset"
     hx-swap="innerHTML"
     hx-sync="this:replace">
  {{template "history_table" .}}
</div>
{{end}}

{{define "history_table"}}
<p class="sub">Thread conversations with per-turn user prompts and Grok replies ({{len .Threads}} threads).</p>

{{if .Threads}}
<div class="table-scroll">
<table>
  <thead>
    <tr>
      <th>Thread</th>
      <th>Project</th>
      <th>Turns</th>
      <th>Last user</th>
      <th>Updated</th>
      <th>Last prompt</th>
    </tr>
  </thead>
  <tbody>
    {{range .Threads}}
    <tr>
      <td class="mono"><a class="tid" href="/history/{{.ThreadID}}">{{.ThreadID}}</a></td>
      <td>{{if .Project}}{{.Project}}{{else}}<span class="muted">—</span>{{end}}</td>
      <td class="mono">{{.TurnCount}}</td>
      <td>{{if .LastUser}}{{.LastUser}}{{else}}<span class="muted">—</span>{{end}}</td>
      <td class="mono muted">{{if .UpdatedAt}}{{.UpdatedAt}}{{else}}—{{end}}</td>
      <td>{{if .LastPrompt}}<span class="clamp muted">{{.LastPrompt}}</span>{{else}}<span class="muted">{{if eq .TurnCount 0}}no turns recorded yet{{else}}—{{end}}</span>{{end}}</td>
    </tr>
    {{end}}
  </tbody>
</table>
</div>
{{else}}
<div class="empty">No history yet. Turns are recorded after Discord threads run Grok tasks.</div>
{{end}}
{{end}}
