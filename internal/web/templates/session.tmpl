{{define "content"}}
<p class="pr-crumb">
  <a href="{{if .Project}}/projects/{{.Project}}/sessions{{else}}{{route "sessions"}}{{end}}">← Sessions</a>
  <span class="crumb-sep">/</span>
  <span class="mono">{{.ThreadID}}</span>
</p>
<div class="pr-title-row">
  <h1 id="page-session">Session <span class="mono" style="font-weight:500;font-size:1.05rem;color:var(--muted)">{{.ThreadID}}</span></h1>
  <div class="pr-head-links">
    {{if .SessionEntry.IsCase}}
    <a class="btn btn-compact" href="/projects/{{.SessionEntry.Project}}/cases">Case board</a>
    {{end}}
    {{if .HasWorktree}}
    <a class="btn btn-compact" href="/sessions/{{.ThreadID}}/diff{{if .Project}}?project={{urlquery .Project}}{{end}}">Worktree diff</a>
    {{else}}
    <a class="btn btn-compact" href="/sessions/{{.ThreadID}}/diff{{if .Project}}?project={{urlquery .Project}}{{end}}" aria-disabled="true" title="Worktree no longer on disk">Worktree diff</a>
    {{end}}
    {{range .SessionEntry.PRs}}
    {{if and .Owner .Repo .Number}}
    <a class="btn btn-compact" href="/prs/{{.Owner}}/{{.Repo}}/{{.Number}}{{if $.Project}}?project={{urlquery $.Project}}{{end}}">PR #{{.Number}}</a>
    {{else if .URL}}
    <a class="btn btn-compact" href="{{.URL}}" target="_blank" rel="noopener">PR{{if .Number}} #{{.Number}}{{end}} ↗</a>
    {{end}}
    {{end}}
    <a class="btn btn-compact" href="/history/{{.ThreadID}}{{if .Project}}?project={{urlquery .Project}}{{end}}">Turn log</a>
    {{if .DiscordURL}}<a class="btn btn-compact" href="{{.DiscordURL}}" target="_blank" rel="noopener">Discord ↗</a>{{end}}
  </div>
</div>
{{if .Project}}
<div class="pr-meta">
  <span><strong>{{.Project}}</strong></span>
  {{if .SessionEntry.IsCase}}
  <span class="badge">case</span>
  {{if .SessionEntry.Phase}}<span class="badge">{{.SessionEntry.Phase}}</span>{{end}}
  {{end}}
</div>
{{end}}
{{if .Flash}}<div class="flash">{{.Flash}}</div>{{end}}
{{if .Error}}<div class="flash err">{{.Error}}</div>{{end}}

<div class="pr-cols">
<div class="pr-main">

{{/* Live work-unit + turns: dashboard ticks while a run is active (elapsed + stream text);
     history fires when a turn is sealed into the log. Continue form stays in the rail so SSE
     swaps do not wipe in-progress prompt text. */}}
<div class="live-region"
     id="live-session"
     hx-get="/partials/sessions/{{.ThreadID}}{{if .NavProject}}?project={{urlquery .NavProject}}{{else if .Project}}?project={{urlquery .Project}}{{end}}"
     hx-trigger="sse:dashboard, sse:history"
     hx-target="this"
     hx-select="unset"
     hx-swap="innerHTML"
     hx-sync="this:queue last">
  {{template "session_live" .}}
</div>

</div>{{/* /pr-main */}}

<aside class="pr-rail">

{{if and .SessionEntry.IsCase (or .CanCaseInvestigate .CanCaseEscalate .CanCaseAnswer .CanCaseDraft .CanCaseClose)}}
{{/* Case phase forms stay outside the live region so SSE swaps do not wipe typed notes. */}}
<div class="rail-group" id="session-case-actions">
  <div class="rail-group-title">Case</div>
  {{if .CanCaseInvestigate}}
  <details class="action" open>
    <summary><span class="action-title">Investigate</span></summary>
    <div class="action-body">
      <form method="post" action="/sessions/{{.ThreadID}}/case/investigate">
        {{template "csrf" $}}
        <div class="field">
          <label for="case-investigate-notes">Notes</label>
          <textarea id="case-investigate-notes" name="notes" rows="3" placeholder="What should Grok look into?"></textarea>
        </div>
        <div class="form-actions"><button type="submit" id="btn-case-investigate">Run investigate</button></div>
      </form>
      <p class="rail-note" style="margin-top:0.55rem">Never opens PRs. Promotes intake → investigate.</p>
    </div>
  </details>
  {{end}}
  {{if .CanCaseEscalate}}
  <details class="action">
    <summary><span class="action-title">Escalate to eng</span></summary>
    <div class="action-body">
      <form method="post" action="/sessions/{{.ThreadID}}/case/escalate">
        {{template "csrf" $}}
        <div class="field">
          <label for="case-escalate-note">Note for eng <span class="muted">(optional)</span></label>
          <textarea id="case-escalate-note" name="note" rows="2" placeholder="Repro, IDs, what you already ruled out"></textarea>
        </div>
        <div class="form-actions"><button type="submit" id="btn-case-escalate" class="btn-secondary">Escalate → fixing</button></div>
      </form>
    </div>
  </details>
  {{end}}
  {{if .CanCaseAnswer}}
  <details class="action">
    <summary><span class="action-title">Answer (knowledge path)</span></summary>
    <div class="action-body">
      <form method="post" action="/sessions/{{.ThreadID}}/case/answer">
        {{template "csrf" $}}
        <div class="field">
          <label for="case-answer-note">Draft for customer <span class="muted">(optional)</span></label>
          <textarea id="case-answer-note" name="note" rows="2" placeholder="Safe wording for the customer"></textarea>
        </div>
        <div class="form-actions"><button type="submit" id="btn-case-answer" class="btn-secondary">Mark answered</button></div>
      </form>
    </div>
  </details>
  {{end}}
  {{if .CanCaseDraft}}
  <details class="action">
    <summary><span class="action-title">Customer update</span></summary>
    <div class="action-body">
      <form method="post" action="/sessions/{{.ThreadID}}/case/customer-update">
        {{template "csrf" $}}
        <div class="field">
          <label for="case-customer-text">Customer-facing text</label>
          <textarea id="case-customer-text" name="text" rows="3" required placeholder="What you can send the customer">{{.SessionEntry.CustomerUpdate}}</textarea>
        </div>
        <div class="form-actions"><button type="submit" id="btn-case-customer">Save update</button></div>
      </form>
      <p class="rail-note" style="margin-top:0.55rem">Sanitizer redacts secrets and local paths.</p>
    </div>
  </details>
  {{end}}
  {{if .CanCaseClose}}
  <details class="action">
    <summary><span class="action-title">Close case</span></summary>
    <div class="action-body">
      <form method="post" action="/sessions/{{.ThreadID}}/case/close" onsubmit="return confirm('Close this case? Reopen is not implemented.')">
        {{template "csrf" $}}
        <div class="field">
          <label for="case-resolution">Resolution</label>
          <select id="case-resolution" name="resolution">
            <option value="answered">answered</option>
            <option value="fixed">fixed</option>
            <option value="duplicate">duplicate</option>
            <option value="wontfix">wontfix</option>
            <option value="escalated_external">escalated_external</option>
          </select>
        </div>
        <div class="field">
          <label for="case-close-note">Note <span class="muted">(optional)</span></label>
          <input type="text" id="case-close-note" name="note" placeholder="Short resolution note">
        </div>
        <div class="form-actions"><button type="submit" id="btn-case-close" class="btn-danger">Close case</button></div>
      </form>
    </div>
  </details>
  {{end}}
</div>
{{end}}

{{if .CanStartSession}}
<div class="rail-group" id="session-continue-form">
  <div class="rail-group-title">Grok</div>
  <details class="action" open>
    <summary><span class="action-title">Continue with Grok</span></summary>
    <div class="action-body">
      <form method="post" action="/sessions/{{.ThreadID}}/continue">
        {{template "csrf" $}}
        <div class="field">
          <label for="continue-prompt">Prompt</label>
          <textarea id="continue-prompt" name="prompt" rows="4" required placeholder="What should Grok do next?"></textarea>
        </div>
        <div class="form-actions"><button type="submit" id="btn-continue">Continue</button></div>
      </form>
      <p class="rail-note" style="margin-top:0.55rem">Queues a follow-up on this work unit only (does not create a new Discord thread).</p>
    </div>
  </details>
</div>

<div class="rail-group" id="session-lifecycle">
  <div class="rail-group-title">Lifecycle</div>
  <details class="action">
    <summary><span class="action-title">Label</span></summary>
    <div class="action-body">
      {{$cur := .SessionEntry.EffectiveLabel}}{{$manual := .SessionEntry.LabelManual}}
      <form method="post" action="/sessions/{{.ThreadID}}/label">
        {{template "csrf" $}}
        <div class="field">
          <label for="session-label">Label</label>
          <select id="session-label" name="label">
            <option value="open"{{if and $manual (eq $cur "open")}} selected{{end}}>open</option>
            <option value="in_progress"{{if and $manual (eq $cur "in_progress")}} selected{{end}}>in progress</option>
            <option value="blocked"{{if and $manual (eq $cur "blocked")}} selected{{end}}>blocked</option>
            <option value="needs_review"{{if and $manual (eq $cur "needs_review")}} selected{{end}}>needs review</option>
            <option value="done"{{if and $manual (eq $cur "done")}} selected{{end}}>done</option>
            <option value="abandoned"{{if and $manual (eq $cur "abandoned")}} selected{{end}}>abandoned</option>
            <option value="auto"{{if not $manual}} selected{{end}}>auto</option>
          </select>
        </div>
        <div class="form-actions"><button type="submit" id="btn-label">Apply label</button></div>
      </form>
    </div>
  </details>
  <details class="action">
    <summary><span class="action-title">Goal</span></summary>
    <div class="action-body">
      <form method="post" action="/sessions/{{.ThreadID}}/goal">
        {{template "csrf" $}}
        <div class="field">
          <label for="session-goal">Sticky goal</label>
          <input type="text" id="session-goal" name="goal" maxlength="200" value="{{.SessionEntry.Goal}}" placeholder="One-line goal for this unit">
        </div>
        <div class="form-actions"><button type="submit" id="btn-goal">Save goal</button></div>
      </form>
    </div>
  </details>
</div>

<div class="rail-group" id="session-ownership">
  <div class="rail-group-title">Ownership</div>
  <p class="rail-note">{{if .SessionEntry.OwnerName}}Owner: <strong>{{.SessionEntry.OwnerName}}</strong>{{else}}Unowned — any member may control it.{{end}}{{if .SessionEntry.CoOwnerIDs}} · {{len .SessionEntry.CoOwnerIDs}} co-owner(s){{end}}</p>
  {{if not (.SessionEntry.IsOwner .UserID)}}
  <form method="post" action="/sessions/{{.ThreadID}}/claim"{{if .SessionEntry.HasOwner}} onsubmit="return confirm('Take over ownership? The current owner becomes a co-owner.')"{{end}}>
    {{template "csrf" $}}
    <div class="form-actions"><button type="submit" id="btn-claim" class="btn-secondary">Claim ownership</button></div>
  </form>
  {{end}}
</div>
{{else}}
<div class="rail-group">
  <div class="rail-group-title">Actions</div>
  <p class="rail-note">Read-only access — continuing this work unit needs a member role with <span class="mono">startSessions</span> enabled.</p>
</div>
{{end}}

{{if .CanControlSession}}
<div class="rail-group" id="session-danger">
  <div class="rail-group-title">Danger zone</div>
  <form method="post" action="/sessions/{{.ThreadID}}/reset" onsubmit="return confirm('Forget session, remove worktree and branch?')">
    {{template "csrf" $}}
    <div class="form-actions"><button type="submit" id="btn-reset" class="btn-danger"{{if .RunBusy}} disabled title="Cancel the active run before resetting"{{end}}>Reset session</button></div>
  </form>
  <p class="rail-note">Removes the worktree, deletes the managed branch, and clears the session. This cannot be undone.</p>
</div>
{{end}}

</aside>
</div>{{/* /pr-cols */}}
{{end}}

{{define "session_live"}}
{{if .SessionEntry.LastVerify}}
<div class="section card" id="session-verify-panel">
  <h2>Last verify</h2>
  <p class="sub" style="margin:0">
    {{if .SessionEntry.LastVerify.OK}}<span class="badge status-done">pass</span>{{else}}<span class="badge status-error">fail</span>{{end}}
    {{if .SessionEntry.LastVerify.Name}} <span class="mono">{{.SessionEntry.LastVerify.Name}}</span>{{end}}
    {{if .SessionEntry.LastVerify.At}} · <span class="mono muted">{{shortTime .SessionEntry.LastVerify.At}}</span>{{end}}
    {{if not .SessionEntry.LastVerify.OK}} · exit <span class="mono">{{.SessionEntry.LastVerify.ExitCode}}</span>{{end}}
  </p>
  {{if .SessionEntry.LastVerify.Summary}}
  <p class="muted" style="margin:0.55rem 0 0">{{.SessionEntry.LastVerify.Summary}}</p>
  {{end}}
  {{if and (not .SessionEntry.LastVerify.OK) .SessionEntry.LastVerify.LogTail}}
  <pre class="mono" style="margin:0.65rem 0 0;padding:0.65rem;background:var(--surface-2);border-radius:6px;font-size:0.78rem;overflow:auto;max-height:12rem;white-space:pre-wrap">{{.SessionEntry.LastVerify.LogTail}}</pre>
  {{end}}
</div>
{{end}}

{{if .SessionEntry.IsCase}}
<div class="section card" id="session-case-panel">
  <h2>Case <span class="muted" style="font-weight:500;font-size:0.9rem">· {{if .SessionEntry.Phase}}{{.SessionEntry.Phase}}{{else}}intake{{end}}</span></h2>
  <p class="sub" style="margin:0">
    <span class="badge">case</span>
    {{if .SessionEntry.Phase}}<span class="badge">{{.SessionEntry.Phase}}</span>{{end}}
    {{if .SessionEntry.Severity}}<span class="badge sev-{{.SessionEntry.Severity}}">{{.SessionEntry.Severity}}</span>{{end}}
    {{if .SessionEntry.IsCaseClosed}}<span class="badge">closed</span>{{end}}
  </p>
  {{if .SessionEntry.CustomerTitle}}
  <p style="margin:0.85rem 0 0"><span class="bubble-label" style="display:block">Title</span>{{.SessionEntry.CustomerTitle}}</p>
  {{end}}
  <p class="sub" style="margin:0.5rem 0 0">
    {{if .SessionEntry.CustomerRef}}ref <span class="mono">{{.SessionEntry.CustomerRef}}</span> · {{end}}
    {{if .SessionEntry.ReporterName}}reporter {{.SessionEntry.ReporterName}}{{else if .SessionEntry.ReporterID}}reporter <span class="mono">{{.SessionEntry.ReporterID}}</span>{{end}}
    {{if .SessionEntry.IntakeSource}} · via <span class="mono">{{.SessionEntry.IntakeSource}}</span>{{end}}
    {{if .SessionEntry.Resolution}} · resolution <span class="mono">{{.SessionEntry.Resolution}}</span>{{end}}
  </p>
  {{if .SessionEntry.CustomerUpdate}}
  <p style="margin:0.85rem 0 0"><span class="bubble-label" style="display:block">Customer update</span>{{.SessionEntry.CustomerUpdate}}</p>
  {{end}}
  {{if .SessionEntry.Dossier}}
  {{if .SessionEntry.Dossier.Summary}}
  <p style="margin:0.85rem 0 0"><span class="bubble-label" style="display:block">Dossier</span>{{.SessionEntry.Dossier.Summary}}</p>
  {{end}}
  {{if .SessionEntry.Dossier.NextActions}}
  <p style="margin:0.55rem 0 0"><span class="bubble-label" style="display:block">Next actions</span>
    {{range $i, $a := .SessionEntry.Dossier.NextActions}}{{if $i}}; {{end}}{{$a}}{{end}}
  </p>
  {{end}}
  {{end}}
</div>
{{end}}

<div class="section card">
  <h2>Work unit</h2>
  <p class="sub" style="margin:0">
    {{if .SessionEntry.Label}}<span class="badge">{{.SessionEntry.Label}}</span>{{else}}<span class="badge">open</span>{{end}}
    {{if .RunBusy}} <span class="badge live">running</span>{{if .RunElapsed}} <span class="mono muted">{{.RunElapsed}}</span>{{end}}{{end}}
    {{if .SessionEntry.Origin}} · origin <span class="mono">{{.SessionEntry.Origin}}</span>{{end}}
    {{if .SessionEntry.OwnerName}} · owner {{.SessionEntry.OwnerName}}{{end}}
    {{if .SessionEntry.WorktreeBranch}} · branch <span class="mono">{{.SessionEntry.WorktreeBranch}}</span>{{end}}
  </p>
  {{if and .RunBusy .CanControlSession}}
  {{/* Button-only form is the sanctioned live-region exception: it holds no typed
       input, so an SSE swap between render and submit at worst flashes "no active run".
       Never place text/textarea inputs inside a live region — refreshes wipe them. */}}
  <form method="post" action="/sessions/{{.ThreadID}}/cancel" style="margin:0.6rem 0 0">
    {{template "csrf" $}}
    <button type="submit" id="btn-cancel-run" class="btn-danger btn-compact">Cancel run</button>
  </form>
  {{end}}
  {{if .SessionEntry.Goal}}
  <p style="margin:0.85rem 0 0"><span class="bubble-label" style="display:block">Goal</span>{{.SessionEntry.Goal}}</p>
  {{end}}
  {{if .QueueItems}}
  <p style="margin:0.85rem 0 0.25rem"><span class="bubble-label" style="display:block">Queue ({{len .QueueItems}})</span></p>
  <ul class="queue-list" style="margin:0;padding-left:1.25rem">
    {{range .QueueItems}}
    <li>
      <span class="mono muted">#{{.Position}}</span>
      {{if .AuthorName}}<strong>{{.AuthorName}}</strong>{{end}}
      {{if .Intent}}<span class="muted">— {{.Intent}}</span>{{end}}
      {{if and $.CanStartSession (or (eq .AuthorID $.UserID) $.CanControlSession)}}
      <form method="post" action="/sessions/{{$.ThreadID}}/queue/remove" style="display:inline;margin-left:0.4rem">
        {{template "csrf" $}}
        <input type="hidden" name="task_id" value="{{.TaskID}}">
        <button type="submit" class="btn-danger btn-compact">Remove</button>
      </form>
      {{end}}
    </li>
    {{end}}
  </ul>
  {{end}}
  {{if .SessionEntry.PRs}}
  <p style="margin:0.85rem 0 0.25rem"><span class="bubble-label" style="display:block">Pull requests</span></p>
  <ul style="margin:0;padding-left:1.25rem">
    {{range .SessionEntry.PRs}}
    <li>
      {{if and .Owner .Repo .Number}}
      <a class="mono" href="/prs/{{.Owner}}/{{.Repo}}/{{.Number}}{{if $.Project}}?project={{urlquery $.Project}}{{end}}">{{.Owner}}/{{.Repo}}#{{.Number}}</a>
      {{else if .Number}}
      <span class="mono">#{{.Number}}</span>
      {{else if .URL}}
      <a class="mono" href="{{.URL}}" target="_blank" rel="noopener">{{.URL}}</a>
      {{else}}
      <span class="muted">PR</span>
      {{end}}
      {{if eq .State "OPEN"}}
      <span class="badge live">{{.State}}</span>
      {{else if eq .State "MERGED"}}
      <span class="badge status-merged">{{.State}}</span>
      {{else if eq .State "CLOSED"}}
      <span class="badge status-cancelled">{{.State}}</span>
      {{else if .State}}
      <span class="badge">{{.State}}</span>
      {{end}}
      {{if .IsDraft}} <span class="badge">draft</span>{{end}}
      {{if .Title}} <span class="muted">— {{.Title}}</span>{{end}}
      {{if and .URL .Owner .Repo .Number}} <a href="{{.URL}}" target="_blank" rel="noopener" title="Open on GitHub">↗</a>{{end}}
    </li>
    {{end}}
  </ul>
  {{end}}
  {{if .SessionEntry.Issues}}
  <p style="margin:0.85rem 0 0.25rem"><span class="bubble-label" style="display:block">Bound issues</span></p>
  <ul style="margin:0;padding-left:1.25rem">
    {{range .SessionEntry.Issues}}
    <li class="mono">{{.DisplayRef}} ({{.EffectiveKeyword}})</li>
    {{end}}
  </ul>
  {{end}}
  {{if .RunBusy}}
  {{if .RunPhases}}<p class="mono" style="margin:0.85rem 0 0">{{.RunPhases}}</p>{{end}}
  {{if .RunActivity}}<p class="muted" style="margin:0.35rem 0 0"><em>{{.RunActivity}}</em></p>{{end}}
  {{else}}
  <p class="muted" style="margin:0.85rem 0 0">No active Grok run on this thread.</p>
  {{end}}
</div>

<div class="section">
  {{$done := len .Thread.Turns}}
  <h2>Turns <span class="muted" style="font-weight:500;font-size:0.9rem">({{if .RunBusy}}{{add $done 1}}{{else}}{{$done}}{{end}})</span></h2>
  {{if or .Thread.Turns .RunBusy}}
  <div class="turns" id="turns">
    {{/* Newest first so long replies do not bury the live/latest turn. #N stays chronological. */}}
    {{if .RunBusy}}
    <article class="turn turn-live" id="turn-live">
      <header class="turn-meta">
        <span class="mono muted">#{{add $done 1}}</span>
        <span class="badge live">streaming</span>
        {{if .RunElapsed}}<span class="mono muted">{{.RunElapsed}}</span>{{end}}
      </header>
      {{if .RunPrompt}}
      <div class="bubble user">
        <div class="bubble-label">User</div>
        <div class="bubble-body md">{{markdown .RunPrompt}}</div>
      </div>
      {{end}}
      <div class="bubble assistant">
        <div class="bubble-label">Grok <span class="muted" style="font-weight:500;text-transform:none;letter-spacing:0">(live)</span></div>
        {{if .RunLiveText}}
        <div class="bubble-body md" id="live-stream-body">{{markdown .RunLiveText}}</div>
        {{else}}
        <div class="bubble-body muted" id="live-stream-body">streaming…</div>
        {{end}}
      </div>
    </article>
    {{end}}
    {{$turns := .Thread.Turns}}
    {{$n := len $turns}}
    {{range $i, $_ := $turns}}
    {{$ri := sub (sub $n 1) $i}}
    {{with $t := index $turns $ri}}
    <article class="turn">
      <header class="turn-meta">
        <span class="mono muted">#{{add $ri 1}}</span>
        <span class="badge status-{{$t.Status}}">{{$t.Status}}</span>
        {{if $t.User}}<span>{{$t.User}}</span>{{end}}
      </header>
      <div class="bubble user">
        <div class="bubble-label">User</div>
        <div class="bubble-body md">{{markdown $t.Prompt}}</div>
      </div>
      <div class="bubble assistant">
        <div class="bubble-label">Grok</div>
        {{if $t.Response}}
        <div class="bubble-body md">{{markdown $t.Response}}</div>
        {{else}}
        <div class="bubble-body muted">(no response text yet)</div>
        {{end}}
      </div>
    </article>
    {{end}}
    {{end}}
  </div>
  {{else}}
  <div class="empty">No turns yet. If a run just started, the live reply will appear here.</div>
  {{end}}
</div>
{{end}}
