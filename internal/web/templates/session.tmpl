{{define "content"}}
<p class="sub" style="margin-bottom:0.5rem"><a href="{{if .Project}}/projects/{{.Project}}/sessions{{else}}{{route "sessions"}}{{end}}">← Sessions</a></p>
<h1 id="page-session">Session <span class="mono" style="font-weight:500;font-size:1.05rem;color:var(--muted)">{{.ThreadID}}</span></h1>
<p class="sub">
  {{if .Project}}<strong>{{.Project}}</strong> · {{end}}
  {{if .DiscordURL}}<a href="{{.DiscordURL}}" target="_blank" rel="noopener">Open in Discord ↗</a> · {{end}}
  <a href="/history/{{.ThreadID}}{{if .Project}}?project={{urlquery .Project}}{{end}}">Turn log</a>
  · <a href="/sessions/{{.ThreadID}}/diff{{if .Project}}?project={{urlquery .Project}}{{end}}">Worktree diff</a>
</p>
{{if .Flash}}<div class="flash">{{.Flash}}</div>{{end}}
{{if .Error}}<div class="flash err">{{.Error}}</div>{{end}}

<div class="section card">
  <h2>Work unit</h2>
  <p class="sub" style="margin:0">
    {{if .SessionEntry.Label}}<span class="badge">{{.SessionEntry.Label}}</span>{{else}}<span class="badge">open</span>{{end}}
    {{if .RunBusy}} <span class="badge live">running</span>{{if .RunElapsed}} <span class="mono muted">{{.RunElapsed}}</span>{{end}}{{if .RunQueue}} <span class="badge">{{.RunQueue}} queued</span>{{end}}{{end}}
    {{if .SessionEntry.Origin}} · origin <span class="mono">{{.SessionEntry.Origin}}</span>{{end}}
    {{if .SessionEntry.OwnerName}} · owner {{.SessionEntry.OwnerName}}{{end}}
    {{if .SessionEntry.WorktreeBranch}} · branch <span class="mono">{{.SessionEntry.WorktreeBranch}}</span>{{end}}
  </p>
  {{if .SessionEntry.Goal}}
  <p style="margin:0.85rem 0 0"><span class="bubble-label" style="display:block">Goal</span>{{.SessionEntry.Goal}}</p>
  {{end}}
  {{if .SessionEntry.Issues}}
  <p style="margin:0.85rem 0 0.25rem"><span class="bubble-label" style="display:block">Bound issues</span></p>
  <ul style="margin:0;padding-left:1.25rem">
    {{range .SessionEntry.Issues}}
    <li class="mono">{{.DisplayRef}} ({{.EffectiveKeyword}})</li>
    {{end}}
  </ul>
  {{end}}
  {{if .RunBusy}}
  {{if .RunPhases}}<p class="mono" style="margin:0.85rem 0 0">{{.RunPhases}}</p>{{end}}
  {{if .RunActivity}}<p class="muted" style="margin:0.35rem 0 0"><em>{{.RunActivity}}</em></p>{{end}}
  {{else}}
  <p class="muted" style="margin:0.85rem 0 0">No active Grok run on this thread.</p>
  {{end}}
</div>

{{if .CanStartSession}}
<div class="section card" id="session-continue-form">
  <h2>Continue with Grok</h2>
  <p class="sub">Queue a follow-up on this work unit only (does not create a new Discord thread).</p>
  <form method="post" action="/sessions/{{.ThreadID}}/continue">
    {{template "csrf" $}}
    <label for="continue-prompt">Prompt</label>
    <textarea id="continue-prompt" name="prompt" rows="4" required placeholder="What should Grok do next?"></textarea>
    <div class="form-actions"><button type="submit" id="btn-continue">Continue</button></div>
  </form>
</div>
{{end}}

<div class="section">
  <h2>Turns <span class="muted" style="font-weight:500;font-size:0.9rem">({{len .Thread.Turns}})</span></h2>
  {{if .Thread.Turns}}
  <div class="turns" id="turns">
    {{range $i, $t := .Thread.Turns}}
    <article class="turn">
      <header class="turn-meta">
        <span class="mono muted">#{{add $i 1}}</span>
        <span class="badge status-{{$t.Status}}">{{$t.Status}}</span>
        {{if $t.User}}<span>{{$t.User}}</span>{{end}}
      </header>
      <div class="bubble user">
        <div class="bubble-label">User</div>
        <pre class="bubble-body">{{$t.Prompt}}</pre>
      </div>
      <div class="bubble assistant">
        <div class="bubble-label">Grok</div>
        {{if $t.Response}}
        <pre class="bubble-body">{{$t.Response}}</pre>
        {{else}}
        <pre class="bubble-body muted">(no response text yet)</pre>
        {{end}}
      </div>
    </article>
    {{end}}
  </div>
  {{else}}
  <div class="empty">No turns yet. If a run just started, refresh after it finishes.</div>
  {{end}}
</div>
{{end}}
