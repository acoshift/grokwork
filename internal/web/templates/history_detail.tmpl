{{define "content"}}
<p class="sub" style="margin-bottom:0.5rem">
  {{if .Project}}
  <a href="/projects/{{.Project}}/sessions">← Sessions</a>
  {{else}}
  <a href="{{route "history"}}">← History</a>
  {{end}}
</p>
<h1 id="page-history-detail">Thread conversation</h1>
{{/* hx-target/hx-select override shell boost (#live-root) so SSE partials swap into the region, not wipe the page. */}}
<div class="live-region"
     id="live-history-turns"
     hx-get="/partials/history/turns/{{.Thread.ThreadID}}{{if .NavProject}}?project={{urlquery .NavProject}}{{else if .Thread.Project}}?project={{urlquery .Thread.Project}}{{end}}"
     hx-trigger="sse:history"
     hx-target="this"
     hx-select="unset"
     hx-swap="innerHTML"
     hx-sync="this:queue last">
  {{template "history_turns" .}}
</div>
{{end}}

{{define "history_turns"}}
<p class="sub">
  <span class="mono">{{.Thread.ThreadID}}</span>
  {{if .Thread.Project}} · <strong>{{.Thread.Project}}</strong>{{end}}
  · {{len .Thread.Turns}} turn{{if ne (len .Thread.Turns) 1}}s{{end}}
  · <a href="/sessions/{{.Thread.ThreadID}}{{if .NavProject}}?project={{urlquery .NavProject}}{{else if .Thread.Project}}?project={{urlquery .Thread.Project}}{{end}}">Work unit</a>
</p>

{{if .Thread.Turns}}
<div class="turns" id="turns">
  {{range $i, $t := .Thread.Turns}}
  <article class="turn" id="turn-{{$i}}">
    <header class="turn-meta">
      <span class="mono muted">#{{add $i 1}}</span>
      <span class="badge status-{{$t.Status}}">{{$t.Status}}</span>
      {{if $t.User}}<span>{{$t.User}}</span>{{end}}
      <span class="mono muted">{{$t.At}}</span>
      {{if $t.ExitCode}}<span class="mono muted" title="exit code">exit {{$t.ExitCode}}</span>{{end}}
      {{if $t.Elapsed}}<span class="muted">{{$t.Elapsed}}</span>{{end}}
      {{if $t.SessionID}}<span class="mono muted" title="session">{{$t.SessionID}}</span>{{end}}
    </header>
    {{with $err := $t.DisplayError}}
    <div class="turn-error{{if eq $t.Status "cancelled"}} turn-error-cancelled{{end}}" role="alert">
      <span class="turn-error-label">{{if eq $t.Status "cancelled"}}Cancelled{{else}}Error{{end}}</span>
      <span class="turn-error-msg">{{$err}}</span>
    </div>
    {{end}}
    <div class="bubble user">
      <div class="bubble-label">User</div>
      <pre class="bubble-body">{{$t.Prompt}}</pre>
    </div>
    <div class="bubble assistant">
      <div class="bubble-label">Grok</div>
      {{if $t.Response}}
      <pre class="bubble-body">{{$t.Response}}</pre>
      {{else}}
      <pre class="bubble-body muted">(no response text)</pre>
      {{end}}
    </div>
  </article>
  {{end}}
</div>
{{else}}
<div class="empty">No turns recorded for this thread yet. New runs will appear here after they finish.</div>
{{end}}
{{end}}
