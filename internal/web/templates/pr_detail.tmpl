{{define "content"}}
{{$open := eq .PR.State "OPEN"}}
<p class="pr-crumb">
  <a href="{{if .Project}}/projects/{{.Project}}/ship{{else}}{{route "ship"}}{{end}}">← Ship board</a>
  <span class="crumb-sep">/</span>
  <span class="mono">{{.ActiveOwner}}/{{.ActiveRepo}}#{{.PRNumber}}</span>
</p>
<div class="pr-title-row">
  <h1 id="page-pr-detail">{{if .PR.Title}}{{.PR.Title}}{{else}}{{.ActiveOwner}}/{{.ActiveRepo}}#{{.PRNumber}}{{end}}</h1>
  <div class="pr-head-links">
    <a class="btn btn-compact" href="/prs/{{.ActiveOwner}}/{{.ActiveRepo}}/{{.PRNumber}}/diff{{if .Project}}?project={{urlquery .Project}}{{end}}">View diff</a>
    {{if .PR.URL}}<a class="btn btn-compact" href="{{.PR.URL}}" target="_blank" rel="noopener">GitHub ↗</a>{{end}}
  </div>
</div>
<div class="pr-meta">
  {{if eq .PR.State "OPEN"}}<span class="badge live">OPEN</span>{{else if eq .PR.State "MERGED"}}<span class="badge status-merged">MERGED</span>{{else if eq .PR.State "CLOSED"}}<span class="badge status-cancelled">CLOSED</span>{{else if .PR.State}}<span class="badge">{{.PR.State}}</span>{{end}}
  {{if .PR.IsDraft}}<span class="badge">draft</span>{{end}}
  {{if .PR.Author}}<span class="mono">{{.PR.Author}}</span>{{end}}
  {{if .PR.HeadRef}}<span class="mono">{{.PR.HeadRef}} → {{.PR.BaseRef}}</span>{{end}}
  {{if .PR.ChangedFiles}}<span class="mono"><span class="diff-add">+{{.PR.Additions}}</span> <span class="diff-del">−{{.PR.Deletions}}</span> · {{.PR.ChangedFiles}} files</span>{{end}}
</div>
{{if .Flash}}<div class="flash">{{.Flash}}</div>{{end}}
{{if .Error}}<div class="flash err">{{.Error}}</div>{{end}}

{{if .PRGates}}
<div class="pr-gates">
  {{range .PRGates}}
  <div class="pr-gate{{if .Class}} {{.Class}}{{end}}">
    <div class="gate-label">{{.Label}}</div>
    <div class="gate-value">{{.Value}}</div>
    {{if .Hint}}<div class="gate-hint">{{.Hint}}</div>{{end}}
  </div>
  {{end}}
</div>
{{end}}

<div class="pr-cols">
<div class="pr-main">

<div class="section card">
  <h2>Description</h2>
  {{if .PR.Body}}<div class="md">{{markdown .PR.Body}}</div>{{if .PR.Truncated}}<p class="muted" style="margin:0.6rem 0 0;font-size:0.8rem">Body truncated.</p>{{end}}{{else}}<p class="muted" style="margin:0">No description.</p>{{end}}
</div>

<div class="section card" id="pr-team-review">
  <div class="team-review-head">
    <h2>Team review</h2>
    <div class="team-review-status">
      {{if .TeamRollupText}}
      <span class="badge{{if .TeamRollupBadge}} {{.TeamRollupBadge}}{{end}}">{{.TeamRollupText}}</span>
      {{end}}
      {{if .PR.ReviewDecision}}
      <span class="muted team-review-gh">GH <span class="mono">{{.PR.ReviewDecision}}</span></span>
      {{end}}
    </div>
  </div>
  <p class="sub team-review-blurb">Discord-attributed team process. Does not satisfy GitHub branch protection.</p>

  {{if .TeamReviews}}
  <div class="table-scroll team-review-history">
  <table>
    <thead>
      <tr>
        <th>When</th>
        <th>Reviewer</th>
        <th>Verdict</th>
        <th>Commit</th>
        <th>Note</th>
      </tr>
    </thead>
    <tbody>
    {{range .TeamReviews}}
      <tr>
        <td class="mono nowrap">{{.Review.At.UTC.Format "2006-01-02 15:04"}}</td>
        <td>{{if .Review.ReviewerName}}{{.Review.ReviewerName}}{{else}}<span class="mono">{{.Review.ReviewerID}}</span>{{end}}</td>
        <td class="team-review-verdict">
          <span class="badge{{if .BadgeClass}} {{.BadgeClass}}{{end}}">{{.LabelText}}</span>
          {{if .Fresh}}
          <span class="badge live">fresh</span>
          {{else if .StickyCR}}
          <span class="badge status-error" title="Still blocking until this reviewer re-reviews">blocking</span>
          {{else}}
          <span class="badge">stale</span>
          {{end}}
        </td>
        <td class="mono" title="{{.Review.HeadSHA}}">{{if .HeadShort}}{{.HeadShort}}{{else}}—{{end}}</td>
        <td class="team-review-note">
          {{if .Review.Body}}<span class="clamp">{{.Review.Body}}</span>{{else}}<span class="muted">—</span>{{end}}
          {{if .Review.GHCommentURL}} <a class="team-review-gh-link" href="{{.Review.GHCommentURL}}" target="_blank" rel="noopener">GH ↗</a>{{end}}
        </td>
      </tr>
    {{end}}
    </tbody>
  </table>
  </div>
  {{else}}
  <p class="muted team-review-empty">No team reviews yet.</p>
  {{end}}

  {{if .TeamPendingRequests}}
  <div class="team-review-block">
    <h3 class="team-review-h3">Pending requests</h3>
    <div class="table-scroll">
    <table>
      <thead><tr><th>Reviewer</th><th>From</th><th>Note</th>{{if $.CanPRReview}}<th></th>{{end}}</tr></thead>
      <tbody>
      {{range .TeamPendingRequests}}
        <tr>
          <td>{{if .ReviewerName}}{{.ReviewerName}}{{else}}<span class="mono">{{.ReviewerID}}</span>{{end}}</td>
          <td class="muted">{{if .RequesterName}}{{.RequesterName}}{{else if .RequesterID}}<span class="mono">{{.RequesterID}}</span>{{else}}—{{end}}</td>
          <td class="team-review-note">{{if .Note}}{{.Note}}{{else}}<span class="muted">—</span>{{end}}</td>
          {{if $.CanPRReview}}
          <td class="row-actions">
            <form method="post" action="/prs/{{$.ActiveOwner}}/{{$.ActiveRepo}}/{{$.PRNumber}}/review-requests/cancel" class="inline">
              {{template "csrf" $}}
              <input type="hidden" name="project" value="{{$.Project}}">
              <input type="hidden" name="requestId" value="{{.ID}}">
              <button type="submit" class="btn-secondary btn-compact">Cancel</button>
            </form>
          </td>
          {{end}}
        </tr>
      {{end}}
      </tbody>
    </table>
    </div>
  </div>
  {{end}}

  {{if not .CanPRReview}}
  <p class="muted team-review-empty" style="margin-top:0.75rem">Requires member role with <span class="mono">prReviews</span> enabled.</p>
  {{end}}
</div>

</div>{{/* /pr-main */}}

<aside class="pr-rail">

{{if and .CanMerge $open}}
<div class="rail-group" id="pr-merge-form">
  <div class="rail-group-title">Ship</div>
  <details class="action"{{if .PRShipReady}} open{{end}}>
    <summary><span class="action-title">Merge pull request</span>{{if .PRShipReady}}<span class="action-hint ok">ready</span>{{else}}<span class="action-hint">gates pending</span>{{end}}</summary>
    <div class="action-body">
      <form method="post" action="/prs/{{.ActiveOwner}}/{{.ActiveRepo}}/{{.PRNumber}}/merge" onsubmit="return confirm('Merge this pull request?');">
        {{template "csrf" $}}
        <input type="hidden" name="project" value="{{.Project}}">
        <div class="field">
          <label for="merge-method">Method</label>
          <select id="merge-method" name="method">
            <option value="squash" {{if eq .WebMergeMethod "squash"}}selected{{end}}>Squash</option>
            <option value="merge" {{if eq .WebMergeMethod "merge"}}selected{{end}}>Merge commit</option>
            <option value="rebase" {{if eq .WebMergeMethod "rebase"}}selected{{end}}>Rebase</option>
          </select>
        </div>
        <label class="check"><input type="checkbox" name="attemptAnyway" value="1"> Attempt even if checks look failing</label>
        <div class="form-actions"><button type="submit">Merge pull request</button></div>
      </form>
    </div>
  </details>
</div>
{{end}}

{{if and .CanPRReview $open}}
<div class="rail-group" id="pr-review-actions">
  <div class="rail-group-title">Review</div>
  <details class="action">
    <summary><span class="action-title">Submit review</span></summary>
    <div class="action-body">
      <form method="post" action="/prs/{{.ActiveOwner}}/{{.ActiveRepo}}/{{.PRNumber}}/reviews" id="pr-review-form">
        {{template "csrf" $}}
        <input type="hidden" name="project" value="{{.Project}}">
        <input type="hidden" name="headSha" value="{{.PR.HeadSHA}}">
        <div class="field">
          <label for="verdict">Verdict</label>
          <select id="verdict" name="verdict" required>
            <option value="approved">Approve</option>
            <option value="changes_requested">Request changes</option>
            <option value="commented">Comment only</option>
          </select>
        </div>
        <div class="field">
          <label for="review-body">Message</label>
          <textarea id="review-body" name="body" rows="3" placeholder="Optional for approve; required for request changes"></textarea>
        </div>
        {{if .CanGitHubWrite}}
        <label class="check"><input type="checkbox" name="mirror" value="1" checked> Mirror to GitHub as a PR comment</label>
        {{end}}
        <div class="form-actions"><button type="submit" id="btn-submit-review">Submit review</button></div>
      </form>
    </div>
  </details>
  {{if .ReviewerOptions}}
  <details class="action">
    <summary><span class="action-title">Request review</span>{{if .TeamPendingRequests}}<span class="action-hint">{{len .TeamPendingRequests}} pending</span>{{end}}</summary>
    <div class="action-body">
      <form method="post" action="/prs/{{.ActiveOwner}}/{{.ActiveRepo}}/{{.PRNumber}}/review-requests" id="pr-request-review-form">
        {{template "csrf" $}}
        <input type="hidden" name="project" value="{{.Project}}">
        <input type="hidden" name="headSha" value="{{.PR.HeadSHA}}">
        <div class="field">
          <label for="reviewerId">Reviewer</label>
          <select id="reviewerId" name="reviewerId" required>
            <option value="">Select teammate…</option>
            {{range .ReviewerOptions}}
            <option value="{{.ID}}">{{.Name}}</option>
            {{end}}
          </select>
        </div>
        <div class="field">
          <label for="review-note">Note (optional)</label>
          <input type="text" id="review-note" name="note" placeholder="What should they focus on?">
        </div>
        <div class="form-actions"><button type="submit" class="btn-secondary" id="btn-request-review">Request review</button></div>
      </form>
    </div>
  </details>
  {{end}}
</div>
{{end}}

{{if .CanStartSession}}
<div class="rail-group" id="pr-address-actions">
  <div class="rail-group-title">Grok</div>
  {{if .ShowFixPicker}}
  <p class="rail-note">Multiple sessions bind this PR — continue one:</p>
  {{range .FixHits}}
  <div class="grok-pick">
    <div class="grok-pick-head">
      <span class="badge">{{.Label}}</span>
      {{if .Busy}}<span class="badge live">busy</span>{{end}}
      <a class="tid mono" href="/sessions/{{.ThreadID}}{{if $.Project}}?project={{urlquery $.Project}}{{end}}">{{.ThreadID}}</a>
    </div>
    {{if .Goal}}<div class="grok-pick-goal">{{.Goal}}</div>{{end}}
    <form method="post" action="/prs/{{$.ActiveOwner}}/{{$.ActiveRepo}}/{{$.PRNumber}}/address-ci" class="grok-pick-actions">
      {{template "csrf" $}}
      <input type="hidden" name="project" value="{{$.Project}}">
      <input type="hidden" name="thread_id" value="{{.ThreadID}}">
      <button type="submit" class="btn-secondary btn-compact">Address CI</button>
      <button type="submit" class="btn-secondary btn-compact" formaction="/prs/{{$.ActiveOwner}}/{{$.ActiveRepo}}/{{$.PRNumber}}/address-review">Address review</button>
    </form>
  </div>
  {{end}}
  <p class="rail-note">Or dispatch a fresh thread:</p>
  {{end}}
  <form method="post" action="/prs/{{.ActiveOwner}}/{{.ActiveRepo}}/{{.PRNumber}}/address-ci" class="grok-dispatch">
    {{template "csrf" $}}
    <input type="hidden" name="project" value="{{.Project}}">
    {{if .ShowFixPicker}}
    <input type="hidden" name="force_new" value="1">
    {{else}}
    <label class="check"><input type="checkbox" name="force_new" value="1"> Always start a new thread</label>
    {{end}}
    <div class="btn-pair">
      <button type="submit" class="btn-secondary" id="btn-address-ci">Address CI</button>
      <button type="submit" class="btn-secondary" id="btn-address-review" formaction="/prs/{{.ActiveOwner}}/{{.ActiveRepo}}/{{.PRNumber}}/address-review">Address review</button>
    </div>
  </form>
  <p class="rail-note">Reuses or opens a Discord work unit. Grok pushes fixes; it never merges.</p>
</div>
{{end}}

{{if .CanGitHubWrite}}
<div class="rail-group" id="pr-comment-form">
  <div class="rail-group-title">GitHub</div>
  <details class="action">
    <summary><span class="action-title">Add comment</span></summary>
    <div class="action-body">
      <form method="post" action="/prs/{{.ActiveOwner}}/{{.ActiveRepo}}/{{.PRNumber}}/comments">
        {{template "csrf" $}}
        <input type="hidden" name="project" value="{{.Project}}">
        <div class="field">
          <label for="pr-body">Comment</label>
          <textarea id="pr-body" name="body" rows="4" required placeholder="Write a comment…"></textarea>
        </div>
        <div class="form-actions"><button type="submit">Post comment</button></div>
      </form>
    </div>
  </details>
  {{if $open}}
  <details class="action danger" id="pr-close-form">
    <summary><span class="action-title">Close pull request</span></summary>
    <div class="action-body">
      <p class="rail-note">Closes without merging. Managed branches clean up on the next sweep.</p>
      <form method="post" action="/prs/{{.ActiveOwner}}/{{.ActiveRepo}}/{{.PRNumber}}/close" onsubmit="return confirm('Close this pull request?');">
        {{template "csrf" $}}
        <input type="hidden" name="project" value="{{.Project}}">
        <div class="form-actions"><button type="submit" class="btn-danger">Close pull request</button></div>
      </form>
    </div>
  </details>
  {{end}}
</div>
{{end}}

{{if not (or .CanMerge .CanPRReview .CanStartSession .CanGitHubWrite)}}
<div class="rail-group">
  <div class="rail-group-title">Actions</div>
  <p class="rail-note">Read-only access — merge, review, and Grok dispatch need a member role with web features enabled.</p>
</div>
{{end}}

</aside>
</div>{{/* /pr-cols */}}
{{end}}
