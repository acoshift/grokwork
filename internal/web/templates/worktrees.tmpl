{{define "content"}}
<h1 id="page-worktrees">{{if .Project}}{{.Project}} <span class="muted" style="font-weight:500;font-size:0.95rem">· worktrees</span>{{else}}Worktrees{{end}}</h1>
<p class="sub">Per-thread git worktrees under <span class="mono">data/worktrees/</span>. Prune removes the worktree, managed branch, and session. Busy threads cannot be pruned.</p>

{{if .Flash}}
<div class="flash">{{.Flash}}</div>
{{end}}
{{if .Error}}
<div class="flash err">{{.Error}}</div>
{{end}}

{{if not .Project}}
<div class="section card">
  <h2>Idle cleanup</h2>
  <form method="post" action="{{route "worktrees.pruneIdle"}}" class="inline" style="grid-template-columns: 1fr auto;" onsubmit="return confirm('Prune all worktrees idle longer than {{.IdleTTLDays}} day(s)?');">
    {{template "csrf" $}}
    <p class="sub" style="margin:0">
      Configured TTL: <span class="mono">{{.IdleTTLDays}}</span> day(s)
      {{if eq .IdleTTLDays 0}}(disabled){{end}}.
      Run a one-shot prune of worktrees past that threshold, across all projects.
    </p>
    <button type="submit" {{if eq .IdleTTLDays 0}}disabled title="Set worktreeIdleTTLDays &gt; 0 on Config"{{end}}>Prune idle now</button>
  </form>
</div>
{{end}}

{{/* hx-target/hx-select override shell boost (#live-root) so SSE partials swap into the region, not wipe the page. */}}
<div class="live-region"
     id="live-worktrees-table"
     hx-get="{{route "partial.worktrees.table"}}{{if .Project}}?project={{urlquery .Project}}{{end}}"
     hx-trigger="sse:worktrees"
     hx-target="this"
     hx-select="unset"
     hx-swap="innerHTML"
     hx-sync="this:queue last">
  {{template "worktrees_table" .}}
</div>
{{end}}

{{define "worktrees_table"}}
<div class="section">
  <h2>{{if .Project}}Project worktrees{{else}}All worktrees{{end}} <span class="muted" style="font-weight:500;font-size:0.9rem">({{len .Worktrees}})</span></h2>
  {{if .Worktrees}}
  <div class="m-rows">
    {{range .Worktrees}}
    <div class="m-row">
      <span class="m-row-main">
        <a class="m-row-t mono tid" href="/sessions/{{.ThreadID}}{{if or $.Project .Project}}?project={{urlquery (or $.Project .Project)}}{{end}}">{{.ThreadID}}</a>
        <span class="m-row-s">{{if and (not $.Project) .Project}}{{.Project}} · {{end}}{{if .Branch}}<span class="mono">{{.Branch}}</span>{{else}}no branch{{end}}{{if .IdleFor}} · idle {{.IdleFor}}{{end}}{{if .IdlePastTTL}} · past TTL{{end}}{{if not .OnDisk}} · missing path{{end}}</span>
      </span>
      {{if .Busy}}
      <span class="badge live">busy</span>
      {{else}}
      <form class="m-row-act" method="post" action="{{route "worktrees.prune"}}" onsubmit="return confirm('Prune worktree for thread {{.ThreadID}}? This removes the worktree, branch, and session.');">
        {{template "csrf" $}}
        <input type="hidden" name="threadId" value="{{.ThreadID}}">
        {{if $.Project}}<input type="hidden" name="project" value="{{$.Project}}">{{end}}
        <button type="submit" class="btn-danger">Prune</button>
      </form>
      {{end}}
    </div>
    {{end}}
  </div>
  <div class="table-scroll m-hide">
  <table>
    <thead>
      <tr>
        <th>Thread</th>
        {{if not .Project}}<th>Project</th>{{end}}
        <th>Branch</th>
        <th>Last active</th>
        <th>Idle</th>
        <th>Status</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {{range .Worktrees}}
      <tr>
        <td class="mono"><a class="tid" href="/sessions/{{.ThreadID}}{{if or $.Project .Project}}?project={{urlquery (or $.Project .Project)}}{{end}}">{{.ThreadID}}</a></td>
        {{if not $.Project}}<td>{{if .Project}}<a href="/projects/{{.Project}}">{{.Project}}</a>{{else}}<span class="muted">—</span>{{end}}</td>{{end}}
        <td class="mono">{{if .Branch}}{{.Branch}}{{else}}<span class="muted">—</span>{{end}}</td>
        <td class="mono muted">{{if .LastActiveAt}}{{.LastActiveAt}}{{else}}—{{end}}</td>
        <td>{{if .IdleFor}}{{.IdleFor}}{{else}}<span class="muted">—</span>{{end}}{{if .IdlePastTTL}} <span class="badge status-warn">past TTL</span>{{end}}</td>
        <td>
          {{if .Busy}}<span class="badge live">busy</span>{{end}}
          {{if .OnDisk}}<span class="badge">on disk</span>{{else}}<span class="badge status-warn">missing path</span>{{end}}
          {{if .HasSession}}<span class="badge">session</span>{{end}}
        </td>
        <td class="row-actions">
          {{if .Busy}}
          <button type="button" class="btn-danger" disabled title="Thread is busy">Prune</button>
          {{else}}
          <form method="post" action="{{route "worktrees.prune"}}" onsubmit="return confirm('Prune worktree for thread {{.ThreadID}}? This removes the worktree, branch, and session.');">
            {{template "csrf" $}}
            <input type="hidden" name="threadId" value="{{.ThreadID}}">
            {{if $.Project}}<input type="hidden" name="project" value="{{$.Project}}">{{end}}
            <button type="submit" class="btn-danger">Prune</button>
          </form>
          {{end}}
        </td>
      </tr>
      {{end}}
    </tbody>
  </table>
  </div>
  {{else}}
  <div class="empty">No thread worktrees found{{if .Project}} in this project{{end}}.</div>
  {{end}}
</div>
{{end}}
