{{define "content"}}
<p class="sub" style="margin-bottom:0.5rem"><a href="/projects/{{.Project}}/issues?owner={{urlquery .ActiveOwner}}&amp;repo={{urlquery .ActiveRepo}}">← Issues</a></p>
<h1 id="page-issue-detail">{{.ActiveOwner}}/{{.ActiveRepo}}#{{.Issue.Number}}</h1>
<p class="sub">
  {{if .Issue.URL}}<a href="{{.Issue.URL}}" target="_blank" rel="noopener">Open on GitHub ↗</a>{{end}}
</p>
{{if .Flash}}<div class="flash">{{.Flash}}</div>{{end}}
{{if .Error}}<div class="flash err">{{.Error}}</div>{{end}}

<div class="section card">
  <h2>{{.Issue.Title}}</h2>
  <p class="sub" style="margin:0">
    {{if eq .Issue.State "open" "OPEN"}}<span class="badge live">{{.Issue.State}}</span>{{else}}<span class="badge">{{.Issue.State}}</span>{{end}}
    · <span class="mono">{{.Issue.Author}}</span>
    {{range .Issue.Labels}} · <span class="badge">{{.}}</span>{{end}}
    {{if .Issue.Truncated}} · <span class="muted">body truncated</span>{{end}}
  </p>
  <pre class="bubble-body" style="margin-top:1rem;white-space:pre-wrap;">{{.Issue.Body}}</pre>
</div>

{{if .Issue.LinkedPRs}}
<div class="section card" id="issue-linked-prs">
  <h2>Related PRs <span class="muted" style="font-weight:500;font-size:0.9rem">({{len .Issue.LinkedPRs}})</span></h2>
  <p class="sub" style="margin:0 0 0.75rem">Pull requests linked as closing references (GitHub Development).</p>
  <div class="table-scroll">
  <table>
    <thead><tr><th>#</th><th>Title</th><th>State</th><th>Repo</th></tr></thead>
    <tbody>
    {{range .Issue.LinkedPRs}}
      <tr>
        <td class="mono">
          {{if and .Owner .Repo .Number}}
          <a href="/prs/{{.Owner}}/{{.Repo}}/{{.Number}}{{if $.Project}}?project={{urlquery $.Project}}{{end}}">#{{.Number}}</a>
          {{else}}
          #{{.Number}}
          {{end}}
          {{if .URL}} <a href="{{.URL}}" target="_blank" rel="noopener" title="Open on GitHub">↗</a>{{end}}
        </td>
        <td>
          {{if and .Owner .Repo .Number}}
          <a class="pr-title" href="/prs/{{.Owner}}/{{.Repo}}/{{.Number}}{{if $.Project}}?project={{urlquery $.Project}}{{end}}">{{if .Title}}{{.Title}}{{else}}#{{.Number}}{{end}}</a>
          {{else if .Title}}{{.Title}}{{else}}<span class="muted">—</span>{{end}}
        </td>
        <td>
          {{if eq .State "OPEN"}}
          <span class="badge live">{{.State}}</span>
          {{else if eq .State "MERGED"}}
          <span class="badge status-merged">{{.State}}</span>
          {{else if eq .State "CLOSED"}}
          <span class="badge status-cancelled">{{.State}}</span>
          {{else if .State}}
          <span class="badge">{{.State}}</span>
          {{else}}
          <span class="muted">—</span>
          {{end}}
          {{if .IsDraft}} <span class="badge">draft</span>{{end}}
        </td>
        <td class="mono muted">{{if and .Owner .Repo}}{{.Owner}}/{{.Repo}}{{else}}—{{end}}</td>
      </tr>
    {{end}}
    </tbody>
  </table>
  </div>
</div>
{{end}}

{{if .CanStartSession}}
<div class="section card" id="issue-fix-form">
  <h2>Fix with Grok</h2>
  <p class="sub">Starts or reuses a Discord work unit for this issue (Fixes bind). Grok opens/updates a PR; it does not merge.</p>
  {{if .ShowFixPicker}}
  <p class="flash">Multiple sessions already bind this issue. Pick one, or force a new thread.</p>
  <div class="table-scroll">
  <table class="table">
    <thead><tr><th>Thread</th><th>Label</th><th>Goal</th><th>Owner</th><th></th></tr></thead>
    <tbody>
    {{range .FixHits}}
      <tr>
        <td class="mono">{{.ThreadID}}</td>
        <td><span class="badge">{{.Label}}</span>{{if .Busy}} <span class="badge live">busy</span>{{end}}</td>
        <td>{{.Goal}}</td>
        <td>{{.OwnerName}}</td>
        <td class="row-actions">
          <form method="post" action="/projects/{{$.Project}}/issues/{{$.Issue.Number}}/fix" style="display:inline">
            {{template "csrf" $}}
            <input type="hidden" name="owner" value="{{$.ActiveOwner}}">
            <input type="hidden" name="repo" value="{{$.ActiveRepo}}">
            <input type="hidden" name="thread_id" value="{{.ThreadID}}">
            <button type="submit" class="btn-secondary" style="height:2rem;font-size:0.82rem;">Continue</button>
          </form>
        </td>
      </tr>
    {{else}}
      <tr><td colspan="5" class="muted">No candidates (they may be terminal).</td></tr>
    {{end}}
    </tbody>
  </table>
  </div>
  {{end}}
  <form method="post" action="/projects/{{.Project}}/issues/{{.Issue.Number}}/fix">
    {{template "csrf" $}}
    <input type="hidden" name="owner" value="{{.ActiveOwner}}">
    <input type="hidden" name="repo" value="{{.ActiveRepo}}">
    <label class="check">
      <input type="checkbox" name="force_new" value="1"> Always start new thread
    </label>
    <div class="form-actions"><button type="submit" id="btn-fix-github">Fix with Grok</button></div>
  </form>
</div>
{{end}}

{{if .CanGitHubWrite}}
<div class="section card" id="issue-comment-form">
  <h2>Add comment</h2>
  <form method="post" action="/projects/{{.Project}}/issues/{{.Issue.Number}}/comments">
    {{template "csrf" $}}
    <input type="hidden" name="owner" value="{{.ActiveOwner}}">
    <input type="hidden" name="repo" value="{{.ActiveRepo}}">
    <label for="issue-body">Comment</label>
    <textarea id="issue-body" name="body" rows="4" required placeholder="Write a comment…"></textarea>
    <div class="form-actions"><button type="submit">Post comment</button></div>
  </form>
</div>
{{end}}

<div class="section">
  <h2>Comments <span class="muted" style="font-weight:500;font-size:0.9rem">({{len .Issue.Comments}})</span></h2>
  {{range .Issue.Comments}}
  <div class="card" style="margin-bottom:0.75rem;">
    <div class="muted mono" style="font-size:0.85rem;">{{.Author}}</div>
    <pre class="bubble-body" style="margin-top:0.5rem;white-space:pre-wrap;">{{.Body}}</pre>
  </div>
  {{else}}
  <div class="empty">No comments.</div>
  {{end}}
</div>
{{end}}
