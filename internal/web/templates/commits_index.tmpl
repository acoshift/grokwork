{{define "content"}}
<h1 id="page-commits">Commits</h1>
<p class="sub">Browse commits on a project’s main checkout. Open a commit to review with Grok and auto-file GitHub issues per finding.</p>
{{if .Error}}<div class="flash err">{{.Error}}</div>{{end}}
<div class="section">
  {{if .Config.ProjectNames}}
  <div class="table-scroll">
  <table>
    <thead><tr><th>Project</th><th>Commits</th></tr></thead>
    <tbody>
    {{range .Config.Projects}}
      <tr>
        <td class="mono">{{.Name}}</td>
        <td><a href="/projects/{{.Name}}/commits">View commits</a></td>
      </tr>
    {{end}}
    </tbody>
  </table>
  </div>
  {{else}}
  <div class="empty">No projects configured.</div>
  {{end}}
</div>
{{end}}
