{{define "content"}}
<div class="pr-title-row">
  <h1 id="page-project-overview">{{.Project}} <span class="muted" style="font-weight:500;font-size:0.95rem">· overview</span></h1>
  {{if .CanStartSession}}
  <div class="pr-head-links">
    <a class="btn btn-compact" href="/projects/{{.Project}}/start">New task</a>
  </div>
  {{end}}
</div>
<p class="sub">Live pulse of this workspace. Queue work by tagging <span class="mono">@Grok</span> in a mapped Discord channel; browse
  <a href="/projects/{{.Project}}/issues">issues</a>{{if .NavLinearEnabled}}, <a href="/projects/{{.Project}}/linear">Linear</a>{{end}}
  or <a href="/projects/{{.Project}}/commits">commits</a> to start from existing work.</p>

{{/* hx-target/hx-select override shell boost (#live-root) so SSE partials swap into the region, not wipe the page. */}}
<div class="live-region"
     id="live-project-pulse"
     hx-get="{{route "partial.project.pulse"}}?project={{urlquery .Project}}"
     hx-trigger="sse:dashboard, sse:ship, sse:cases"
     hx-target="this"
     hx-select="unset"
     hx-swap="innerHTML"
     hx-sync="this:queue last">
  {{template "project_pulse" .}}
</div>

<div class="section">
  <h2>Recent sessions <span class="muted" style="font-weight:500;font-size:0.9rem">({{len .Threads}} shown)</span></h2>
  {{if .Threads}}
  <div class="m-rows">
    {{range .Threads}}
    <a class="m-row" href="/sessions/{{.ThreadID}}?project={{urlquery $.Project}}">
      <span class="m-row-main">
        {{if .LastPrompt}}
        <span class="m-row-t">{{.LastPrompt}}</span>
        {{else}}
        <span class="m-row-t mono">{{.ThreadID}}</span>
        {{end}}
        <span class="m-row-s">{{if .LastPrompt}}<span class="mono">{{.ThreadID}}</span> · {{end}}{{.TurnCount}} turn{{if ne .TurnCount 1}}s{{end}}{{if .LastUser}} · {{.LastUser}}{{end}}{{if .UpdatedAt}} · {{.UpdatedAt}}{{end}}</span>
      </span>
    </a>
    {{end}}
  </div>
  <div class="table-scroll m-hide">
  <table>
    <thead>
      <tr>
        <th>Thread</th>
        <th>Turns</th>
        <th>Last user</th>
        <th>Updated</th>
        <th>Last prompt</th>
      </tr>
    </thead>
    <tbody>
      {{range .Threads}}
      <tr>
        <td class="mono"><a class="tid" href="/sessions/{{.ThreadID}}?project={{urlquery $.Project}}">{{.ThreadID}}</a></td>
        <td class="mono">{{.TurnCount}}</td>
        <td>{{if .LastUser}}{{.LastUser}}{{else}}<span class="muted">—</span>{{end}}</td>
        <td class="mono muted">{{if .UpdatedAt}}{{.UpdatedAt}}{{else}}—{{end}}</td>
        <td>{{if .LastPrompt}}<span class="clamp muted">{{.LastPrompt}}</span>{{else}}<span class="muted">{{if eq .TurnCount 0}}no turns recorded yet{{else}}—{{end}}</span>{{end}}</td>
      </tr>
      {{end}}
    </tbody>
  </table>
  </div>
  {{else}}
  <div class="empty">No sessions in this project yet. Tag <span class="mono">@Grok</span> in a mapped Discord channel to start one.</div>
  {{end}}
</div>
{{end}}

{{define "project_pulse"}}
<div class="grid" id="pulse">
  <div class="card">
    <div class="label">Running</div>
    <div class="value" id="pulse-running">{{.Status.ActiveCount}}</div>
    <div class="hint">{{if gt .Status.ActiveCount 0}}<span class="badge live">running</span>{{else}}idle{{end}}</div>
  </div>
  <div class="card">
    <div class="label">Queued</div>
    <div class="value" id="pulse-queued">{{.Status.QueuedTotal}}</div>
    <div class="hint">follow-ups waiting</div>
  </div>
  <div class="card">
    <div class="label">Open PRs</div>
    <div class="value" id="pulse-open">{{.Ship.Open}}</div>
    <div class="hint"><a href="/projects/{{.Project}}/ship">{{.Ship.Draft}} draft · ship board</a></div>
  </div>
  <div class="card">
    <div class="label">CI failing</div>
    <div class="value" id="pulse-failing">{{.Ship.ChecksFailing}}</div>
    <div class="hint">{{if gt .Ship.ChecksFailing 0}}<span class="badge status-error">needs attention</span>{{else}}all green{{end}}</div>
  </div>
  <div class="card">
    <div class="label">Open cases</div>
    <div class="value" id="pulse-cases-open">{{.Cases.OpenTotal}}</div>
    <div class="hint"><a href="/projects/{{.Project}}/cases">case board</a>{{if gt .Cases.Closed 0}} · {{.Cases.Closed}} closed{{end}}</div>
  </div>
  <div class="card">
    <div class="label">Looking into it</div>
    <div class="value" id="pulse-cases-investigate">{{.Cases.Investigate}}</div>
    <div class="hint">{{.Cases.Intake}} intake · {{.Cases.Answered}} answered</div>
  </div>
  <div class="card">
    <div class="label">With engineering</div>
    <div class="value" id="pulse-cases-eng">{{add .Cases.Fixing .Cases.Shipping}}</div>
    <div class="hint">{{.Cases.Fixing}} fixing · {{.Cases.Shipping}} shipping</div>
  </div>
</div>
{{if .Status.ActiveRuns}}
<div class="m-rows" style="margin-bottom:1.5rem">
  {{range .Status.ActiveRuns}}
  <a class="m-row" href="/sessions/{{.ThreadID}}?project={{urlquery $.Project}}">
    <span class="m-row-main">
      <span class="m-row-t mono">{{.ThreadID}}</span>
      <span class="m-row-s">{{if .Activity}}{{.Activity}} · {{end}}running {{.Elapsed}}</span>
    </span>
    {{if gt .QueueLen 0}}<span class="badge">{{.QueueLen}} queued</span>{{else}}<span class="badge live">live</span>{{end}}
  </a>
  {{end}}
</div>
<div class="table-scroll m-hide" style="margin-bottom:1.5rem">
<table>
  <thead>
    <tr><th>Thread</th><th>Elapsed</th><th>Activity</th><th>Queue</th></tr>
  </thead>
  <tbody>
    {{range .Status.ActiveRuns}}
    <tr>
      <td class="mono"><a class="tid" href="/sessions/{{.ThreadID}}?project={{urlquery $.Project}}">{{.ThreadID}}</a></td>
      <td class="mono">{{.Elapsed}}</td>
      <td>{{if .Activity}}<span class="clamp muted">{{.Activity}}</span>{{else}}<span class="muted">—</span>{{end}}</td>
      <td>{{if gt .QueueLen 0}}<span class="badge">{{.QueueLen}} queued</span>{{else}}<span class="muted">—</span>{{end}}</td>
    </tr>
    {{end}}
  </tbody>
</table>
</div>
{{end}}
{{end}}
